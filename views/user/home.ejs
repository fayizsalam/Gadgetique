    <script>

        // ⭐ API HELPER (place this at the top)
        async function api(url, options = {}) {
        
          try {
        
            const res = await fetch(url, {
              headers: { "Content-Type": "application/json" },
              ...options
            });
        
            if (!res.ok) throw new Error("Network error");
        
            return await res.json();
        
          } catch (err) {
        
            console.error(err);
            handleAction("Something went wrong");
        
          }
      
        }
        


      

        //Add to Cart
        let cart = [];

        // --- Quick View Logic ---
        function openQuickView(id, name, price, img, desc, stock=0) {
  const modal = document.getElementById("quickViewModal");

  const addBtn = document.getElementById("qvAddToCartBtn");
  const wishBtn = document.getElementById("qvWishlistBtn");

  document.getElementById("qvName").innerText = name;
  document.getElementById("qvPrice").innerText = `₹${price.toLocaleString("en-IN")}`;
  document.getElementById("qvDescription").innerText =
    desc || "Experience top-tier performance and sleek design with our latest premium hardware.";
  document.getElementById("qvImage").src = img;

  // RESET BUTTON STATES
  addBtn.disabled = false;
  wishBtn.disabled = false;

  addBtn.classList.remove("opacity-50", "cursor-not-allowed");
  wishBtn.classList.remove("opacity-50", "cursor-not-allowed");

  addBtn.innerText = "Add to Cart";

  if (stock <= 0) {
    // 🚫 OUT OF STOCK
    addBtn.disabled = true;
    wishBtn.disabled = true;

    addBtn.innerText = "Out of Stock";

    addBtn.classList.add("opacity-50", "cursor-not-allowed");
    wishBtn.classList.add("opacity-50", "cursor-not-allowed");

    addBtn.onclick = () => handleAction("Item Out of Stock");
    wishBtn.onclick = () => handleAction("Item Out of Stock");
  } else {
    // ✅ IN STOCK
    addBtn.onclick = () => {
      addToCart(id, name, price, img, stock);
      closeQuickView();
    };

    wishBtn.onclick = () => {
      toggleWishlist(id, name, price, img);
    };
  }

  modal.classList.remove("hidden");
  document.body.style.overflow = "hidden";
}

        function closeQuickView() {
            document.getElementById('quickViewModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        // --- Drawer Controls ---
        function toggleDrawer(id) {
            const drawer = document.getElementById(id);
            const overlay = document.getElementById('drawerOverlay');
            
            // Close other drawers if open
            document.querySelectorAll('.side-drawer').forEach(d => {
                if(d.id !== id) d.classList.remove('open');
            });

            const isOpen = drawer.classList.toggle('open');
            overlay.classList.toggle('hidden', !isOpen);
            document.body.style.overflow = isOpen ? 'hidden' : 'auto';
        }

        function closeAllDrawers() {
            document.querySelectorAll('.side-drawer').forEach(d => d.classList.remove('open'));
            document.getElementById('drawerOverlay').classList.add('hidden');
            document.body.style.overflow = 'auto';
            closeQuickView();
        }

        //---- Cart Functions-----
        async function addToCart(productId) {

            const data = await api("/auth/cart/add", {
              method: "POST",
              body: JSON.stringify({ productId })
            });
        
            if (data.success) {
              handleAction("Added to Cart");
              updateCartBadge();
            }
        }

        async function removeItem(productId) {

  await fetch("/auth/cart/remove", {

    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },

    body: JSON.stringify({ productId })

  });

  location.reload();

}

        async function updateQty(productId, action) {

  await fetch("/auth/cart/update", {

    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },

    body: JSON.stringify({
      productId,
      action
    })

  });

  location.reload();

}

        function updateCart() {
            const container = document.getElementById('cartItemsContainer');
            const totalDisplay = document.getElementById('cartTotalDisplay');
            const navTotal = document.getElementById('navCartTotal');
            const badge = document.getElementById('cartBadge');
            
            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-24 flex flex-col items-center justify-center">
                        <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </div>
                        <p class="text-slate-500 font-medium">Your cart is empty</p>
                        <button onclick="closeAllDrawers()" class="mt-4 text-violet-600 text-sm font-semibold hover:underline">Start Shopping</button>
                    </div>`;
                totalDisplay.innerText = "₹0.00";
                if(navTotal) navTotal.innerText = "₹0";
                
                badge.style.opacity = "0";
                badge.style.transform = "scale(0)";
                return;
            }

            badge.innerText = cart.reduce((acc, i) => acc + i.qty, 0);
            badge.style.opacity = "1";
            badge.style.transform = "scale(1)";

            let total = 0;
            container.innerHTML = cart.map(item => {
                const subtotal = item.price * item.qty;
                total += subtotal;
                return `
                    <div class="flex gap-4 items-start bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                        <img src="${item.img}" class="w-20 h-20 rounded-lg object-cover bg-slate-50">
                        <div class="flex-1">
                            <h4 class="font-bold text-sm text-slate-900 line-clamp-1 font-serif">${item.name}</h4>
                            <p class="text-slate-500 text-xs mt-1">₹${item.price.toLocaleString()}</p>
                            <div class="flex items-center gap-3 mt-3">
                                <button onclick="updateQty('${item.id}', -1)" class="w-6 h-6 flex items-center justify-center rounded-full bg-slate-100 hover:bg-slate-200 text-slate-600 transition">-</button>
                                <span class="text-sm font-bold text-slate-900 w-4 text-center">${item.qty}</span>
                                <button onclick="updateQty('${item.id}', 1)" class="w-6 h-6 flex items-center justify-center rounded-full bg-slate-100 hover:bg-slate-200 text-slate-600 transition">+</button>
                            </div>
                        </div>
                        <div class="flex flex-col items-end gap-2 justify-between h-20">
                             <button onclick="removeFromCart('${item.id}')" class="text-slate-400 hover:text-rose-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
                             <span class="font-bold text-violet-700 text-sm">₹${subtotal.toLocaleString()}</span>
                        </div>
                    </div>
                `;
            }).join('');

            totalDisplay.innerText = `₹${total.toLocaleString("en-IN")}`;
            if(navTotal) navTotal.innerText = `₹${total.toLocaleString("en-IN")}`;
            localStorage.setItem("cart", JSON.stringify(cart));

        }

        function toggleCart() {
            const drawer = document.getElementById('cartDrawer');
            const overlay = document.getElementById('drawerOverlay');

            const isOpen = drawer.classList.toggle('open');
            overlay.classList.toggle('hidden', !isOpen);
            document.body.style.overflow = isOpen ? 'hidden' : 'auto';
        }

        async function updateCartBadge() {

  try {

    const res = await fetch("/auth/cart/count");
    const data = await res.json();

    const badge = document.getElementById("cartBadge");

    badge.innerText = data.count;

    if (data.count > 0) {
      badge.style.opacity = "1";
      badge.style.transform = "scale(1)";
    } else {
      badge.style.opacity = "0";
      badge.style.transform = "scale(0)";
    }
    

  } catch (error) {
    console.log(error);
  }

}

    //---- Wishlist Functions ----

async function toggleWishlist(event, productId, button){

    event.stopPropagation();

    try{

        const res = await fetch(`/auth/wishlist/add/${productId}`,{
            method:'POST'
        });

        const data = await res.json();

        const icon = button.querySelector("svg");

        if(data.added){

            icon.classList.remove("text-slate-400","fill-none");
            icon.classList.add("text-red-500","fill-red-500");

            handleAction("Added to Wishlist ❤️");

        }else{

            icon.classList.remove("text-red-500","fill-red-500");
            icon.classList.add("text-slate-400","fill-none");

            handleAction("Removed from Wishlist");

        }

        updateWishlistCount();

    }catch(err){
        console.error(err);
    }
}
        
    
async function updateWishlistCount(){

    try{

        const res = await fetch("/auth/wishlist/count");
        const data = await res.json();

        const badge = document.getElementById("wishlistCount");

        badge.innerText = data.count;

    if (data.count > 0) {
      badge.style.opacity = "1";
      badge.style.transform = "scale(1)";
    } else {
      badge.style.opacity = "0";
      badge.style.transform = "scale(0)";
    }

  } catch (error) {
    console.log(error);
  }

}

updateWishlistCount();


    
    //Sysytem Notification
        function handleAction(action) {
            const box = document.getElementById('messageBox');
            const content = document.getElementById('messageContent');
            const title = document.getElementById('messageTitle');
            
            title.innerText = "System Notification";
            content.innerText = `${action}`;
            
            box.classList.remove('hidden');
            box.classList.add('flex');
            box.classList.add('translate-y-2');
            
            setTimeout(() => {
                 box.classList.remove('translate-y-2');
                 hideMessage();
            }, 3000);
        }

        function hideMessage() {
            const box = document.getElementById('messageBox');
            box.classList.add('hidden');
            box.classList.remove('flex');
        }

        //Copy Coupen
        function copyCoupon() {
            const code = document.getElementById('couponCode').innerText;
            const tempInput = document.createElement("input");
            tempInput.value = code;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);

            const copyText = document.getElementById('copyText');
            const originalText = copyText.innerText;
            const icon = document.getElementById('copyIcon');
            
            copyText.innerText = "COPIED";
            copyText.classList.add('text-green-600');
            icon.classList.add('text-green-600');
            
            setTimeout(() => {
                copyText.innerText = originalText;
                copyText.classList.remove('text-green-600');
                icon.classList.remove('text-green-600');
            }, 2000);
        }

        // --- Navigation Link Active State ---
        function setActiveLink(clickedElement) {
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('nav-link-active');
            });
            clickedElement.classList.add('nav-link-active');
        }


        

        // --- Slider Logic ---
        let currentSlide = 0;
        const sliderTrack = document.getElementById('slider-track');

        if (sliderTrack) {
            const slides = sliderTrack.children;
            const totalSlides = slides.length;
            let slideInterval;

            function updateSlider() {
                if (currentSlide < 0) {
                    currentSlide = totalSlides - 1;
                } else if (currentSlide >= totalSlides) {
                    currentSlide = 0;
                }
                const offset = -currentSlide * 100;
                sliderTrack.style.transform = `translateX(${offset}%)`;
            }

            window.nextSlide = function () {
                currentSlide++;
                updateSlider();
            }

            window.prevSlide = function () {
                currentSlide--;
                updateSlider();
            }

            function startAutoSlide() {
                pauseAutoSlide();
                slideInterval = setInterval(nextSlide, 5000);
            }

            function pauseAutoSlide() {
                clearInterval(slideInterval);
            }

            const carousel = document.getElementById('product-carousel');
            if (carousel) {
                carousel.addEventListener('mouseenter', pauseAutoSlide);
                carousel.addEventListener('mouseleave', startAutoSlide);
            }

            startAutoSlide();
            updateSlider();
        }
    
        document.addEventListener("DOMContentLoaded", () => {
        updateCart();
        updateWishlistBadge();
        });

        // 🔍 Live Search Function
        const searchInput = document.getElementById("searchInput");

        if (searchInput) {
    searchInput.addEventListener("input", function () {
    const query = this.value.toLowerCase().trim();
    const cards = document.querySelectorAll(".product-card");

    cards.forEach((card) => {
      const name = card.dataset.name;
      const description = card.dataset.description;

      if (name.includes(query) || description.includes(query)) {
        card.style.display = "block";
      } else {
        card.style.display = "none";
      }
    });
  });
}

 function goToSearchResults() {
  const input = document.getElementById("searchInput");
  const target = document.getElementById("new-arrivals");
  input.focus();
  target.scrollIntoView({
    behavior: "smooth",
    block: "start"
  });
}
    
    // Scroll Animation for Product Cards
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add("show");
    }
  });
}, {
  threshold: 0.15
});

document.querySelectorAll(".product-card").forEach((card) => {
  observer.observe(card);
});

//Load Badge on Page Load
document.addEventListener("DOMContentLoaded", () => {

  updateCartBadge();

});
    
    </script>
</body>

</html>