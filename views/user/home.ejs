<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gadgetique | Premium Tech</title>


    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Professional Typography */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            /* Pure White */
            color: #1e293b;
            /* Slate 800 */
        }

        h1, h2, h3, .brand-font {
            font-family: 'Playfair Display', serif;
        }

        .text-primary {
            color: #7c3aed;
            /* Violet 600 */
        }

        .bg-primary {
            background-color: #7c3aed;
        }

        .bg-glass {
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
        }

        .action-icon {
            @apply p-2.5 rounded-full transition duration-300 text-slate-500 hover:bg-violet-50 hover:text-violet-600;
        }

        /* Modern Nav Links */
        .nav-link {
            @apply px-5 py-2.5 font-medium text-sm text-slate-600 rounded-full transition-all duration-300 hover:bg-slate-50 hover:text-violet-700;
        }

        .nav-link-active {
            @apply bg-violet-50 text-violet-700 font-semibold shadow-sm ring-1 ring-violet-100;
        }

        .footer-link {
            @apply text-slate-400 hover:text-white transition duration-200 block mb-3 text-sm font-medium;
        }

        .footer-heading {
            @apply text-xs font-bold uppercase tracking-widest mb-6 text-white opacity-80;
        }

        /* Slide Card Height */
        .slide-card-height {
            height: 30rem;
        }

        @media (min-width: 768px) {
            .slide-card-height {
                height: 26rem;
            }
        }
        
        /* Ticker Animation */
        @keyframes ticker {
            0% { transform: translateX(0%); }
            100% { transform: translateX(-50%); }
        }

        .animate-ticker {
            display: inline-block;
            white-space: nowrap;
            animation: ticker 40s linear infinite;
        }

        /* Side Drawers */
        .side-drawer.open {
            transform: translateX(0);
        }
        .side-drawer {
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        /* Product Card Styling */
        .product-card {
            transition: all 0.4s ease;
        }
        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.01);
        }

        .gradient-text {
            background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
         .nav-link {
    position: relative;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569; /* slate-600 */
    transition: color 0.25s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: 0;
    height: 2px;
    background-color: #7c3aed; /* violet-600 */
    border-radius: 9999px;
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .nav-link:hover {
    color: #7c3aed;
  }

  .nav-link:hover::after {
    width: 70%;
  }

  .nav-link-active {
    color: #7c3aed;
    font-weight: 600;
  }

  .nav-link-active::after {
    width: 70%;
  }

  /* Clearance special */
  .nav-link-clearance:hover {
    color: #e11d48; /* rose-600 */
  }

  .nav-link-clearance::after {
    background-color: #e11d48;
  }
  html {
  scroll-behavior: smooth;
}

/* Scroll Animation */
.product-card {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.product-card.show {
  opacity: 1;
  transform: translateY(0);
}
/*Account Drop Down*/
#accountDropdownMenu {
  transition: all 0.25s ease;
  transform: translateY(10px);
}

.group:hover #accountDropdownMenu {
  transform: translateY(0);
}

.wishlist-animate {
    animation: heartPop 0.3s ease;
}

@keyframes heartPop {
    0% { transform: scale(1); }
    50% { transform: scale(1.4); }
    100% { transform: scale(1); }
}

    .wishlist-icon{
transition: all 0.25s ease;
}

.wishlist-icon.text-red-500{
transform: scale(1.2);
}

    </style>
</head>

<body class="antialiased text-slate-900 overflow-x-hidden">

    <!-- Notification Toast -->
    <div id="messageBox" class="fixed top-24 right-5 bg-white shadow-2xl rounded-xl p-4 flex items-center gap-4 transform transition-all duration-300 z-[100] border-l-4 border-violet-600 hidden max-w-sm ring-1 ring-black/5">
        <div>
            <h4 class="font-bold text-sm text-slate-900" id="messageTitle">Notification</h4>
            <p id="messageContent" class="text-xs text-slate-500 mt-1">Action completed.</p>
        </div>
        <button onclick="hideMessage()" class="text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </div>

    <!-- Overlay -->
    <div id="drawerOverlay" class="fixed inset-0 bg-slate-900/40 backdrop-blur-[2px] z-[60] hidden transition-opacity duration-300" onclick="closeAllDrawers()"></div>

    <!-- Quick View Modal -->
    <div id="quickViewModal" class="fixed inset-0 z-[80] hidden flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeQuickView()"></div>
        <div class="bg-white rounded-3xl w-full max-w-4xl overflow-hidden shadow-2xl relative animate-in fade-in zoom-in duration-300 flex flex-col md:flex-row">
            <button onclick="closeQuickView()" class="absolute top-4 right-4 z-10 p-2 bg-white/80 backdrop-blur-md rounded-full text-slate-500 hover:text-slate-900 shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            
            <div class="md:w-1/2 h-80 md:h-auto bg-slate-50">
                <img id="qvImage" src="" class="w-full h-full object-cover">
            </div>
            
            <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
                <span class="text-violet-600 font-bold tracking-widest text-[10px] uppercase mb-2 block">Premium Tech</span>
                <h3 id="qvName" class="text-3xl font-bold text-slate-900 mb-4 brand-font">Product Name</h3>
                <p id="qvPrice" class="text-2xl text-red-700 mb-6 font-semibold">₹0.00</p>
                <div class="mb-8">
                    <h4 class="text-xs font-bold uppercase text-slate-400 tracking-wider mb-2">Description</h4>
                    <p id="qvDescription" class="text-slate-500 leading-relaxed font-light">Product description goes here.</p>
                </div>
                
                <div class="grid grid-cols-2 gap-4 mb-8">
                    <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                        <p class="text-[10px] text-slate-400 uppercase font-bold">Shipping</p>
                        <p class="text-xs font-semibold text-slate-700">2-4 Business Days</p>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                        <p class="text-[10px] text-slate-400 uppercase font-bold">Warranty</p>
                        <p class="text-xs font-semibold text-slate-700">1 Year Limited</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <button id="qvAddToCartBtn" class="flex-grow py-4 bg-slate-900 hover:bg-violet-700 text-white font-medium rounded-xl shadow-lg transition-all transform active:scale-[0.98]">
                        Add to Cart
                    </button>
                    <button id="qvWishlistBtn" class="px-5 py-4 border border-slate-200 rounded-xl hover:bg-rose-50 hover:text-rose-500 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- Navigation -->
    <header class="sticky top-0 z-30 bg-glass border-b border-slate-100/50 backdrop-blur-xl transition-all duration-300">

        <!-- PROMO BAR -->
        <div class="w-full bg-gradient-to-r from-violet-900 via-indigo-900 to-slate-900 overflow-hidden py-3 cursor-pointer relative z-40" onclick="handleAction('Comming Soon...')">
            <div class="animate-ticker whitespace-nowrap">
                <div class="px-4 text-[11px] font-bold tracking-[0.2em] text-white/90 flex items-center gap-16 uppercase">
                    <span>Free Global Shipping on Orders Over ₹5,000</span>
                    <span class="text-white/30">•</span>
                    <span>Cyber Week: Up to 40% Off Select Hardware</span>
                    <span class="text-white/30">•</span>
                    <span>Use Code "WELCOME2026" for Extra Discount</span>
                    <span class="text-white/30">•</span>
                    <span>New Arrivals: The Future is Here</span>
                    <span class="text-white/30">•</span>
                    <span>Join the Gadgetique Elite Club</span>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between gap-8">

            <div class="flex-shrink-0">
                <a href="#" class="text-3xl font-extrabold tracking-tight gradient-text brand-font">
                    Gadgetique.
                </a>
            </div>

            <!-- Search Bar -->
            <div class="hidden lg:block flex-grow max-w-lg mx-auto">
                <div class="relative w-full group">
                    <input id="searchInput" type="text" placeholder="Search for products..."
                        class="w-full py-3 pl-5 pr-12 text-slate-700 bg-slate-50 border border-slate-200 rounded-full focus:outline-none focus:bg-white focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all duration-300 shadow-sm group-hover:shadow-md">
                    <button class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 group-hover:text-violet-600 transition-colors"
                        onclick="goToSearchResults()">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Icons -->
            <div class="flex items-center gap-3">

                <!-- Wishlist -->
                 <a href="/auth/wishlist" class="relative">
                    <svg class="w-7 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    <span id="wishlistCount" class="absolute top-0 right-0 bg-rose-500 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full opacity-0 scale-0 transition-all duration-300">0</span>
                </a>
                

                <!-- Cart -->
                 <a href="/auth/cart" class="action-icon relative group block">
                    <div class="relative">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                        </svg>
                        <span id="cartBadge" class="absolute -top-0 -right-1 bg-violet-600 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full opacity-0 scale-0 transition-all duration-300">0</span>
                    </div>
                </a>
                

                <div class="relative z-40 ml-2 group">
                     <!--User Name Button -->
                    <button id="accountDropdownButton"
                        class="flex items-center gap-2 px-1 py-1 rounded-full hover:bg-slate-50 transition duration-200 focus:outline-none ring-2 ring-transparent focus:ring-slate-100">
                        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-100 to-fuchsia-100 flex items-center justify-center text-violet-700 font-bold text-xs shadow-inner">
                             <span><%= user.charAt(0).toUpperCase() %></span>
                        </div>
                    </button>
                    <!-- Drop down Menu -->
                    <div id="accountDropdownMenu" class="absolute left-0 mt-1 w-48 bg-white border border-slate-100 rounded-2xl shadow-xl py-2 z-50 transform origin-top-right transition-all opacity-0 invisible group-hover:opacity-100 group-hover:visible">
                        <div class="px-5 py-4 border-b border-slate-50">
                             <p class="text-xs text-slate-400 uppercase font-bold tracking-wider mb-1">Signed in as</p>
                             <p class="text-sm font-semibold text-slate-900 truncate"><%= user %></p>
                        </div>
                        <form action="/auth/profile" method="get">
                            <button type="submit" class="text-left block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors w-full">My Profile</button>
                        </form>
                        <!-- <a href="" class="block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors"></a> -->
                         <form action="/auth/orders" method="get">
                            <button type="submit" class="text-left block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors w-full">My Orders</button>
                        </form>
                        <div class="border-t border-slate-50 mt-1"></div>
                        <form action="/auth/logout" method="get">
                            <button type="submit" class="w-full text-left px-5 py-3 text-sm text-rose-500 hover:bg-rose-50 font-medium transition-colors rounded-b-xl">Sign Out</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Secondary Nav -->
        <nav class="border-t border-slate-100 bg-white/50 backdrop-blur-sm">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between lg:justify-center h-14 overflow-x-auto no-scrollbar">

                    <div class="hidden lg:flex items-center space-x-4">
                        <a href="/auth/home?category=all#new-arrivals" class="nav-link <%= selectedCategory === 'all' ? 'nav-link-active' : '' %>">All Products</a>
                        <a href="/auth/home?category=home#new-arrivals" class="nav-link <%= selectedCategory === 'home' ? 'nav-link-active' : '' %>">Home Gadgets</a>
                        <a href="/auth/home?category=gaming#new-arrivals" class="nav-link <%= selectedCategory === 'gaming' ? 'nav-link-active' : '' %>">Gaming</a>
                        <a href="/auth/home?category=travel#new-arrivals" class="nav-link <%= selectedCategory === 'travel' ? 'nav-link-active' : '' %>" onclick="setActiveLink(this)">Travel</a>
                        <a href="/auth/home?category=clearance#new-arrivals" class="nav-link nav-link-clearance <%= selectedCategory === 'clearance' ? 'nav-link-active' : '' %>">Clearance Sale</a>
                    </div>

                    <div class="lg:hidden flex  -grow">
                        <select class="w-full py-2 px-4 bg-slate-50 text-slate-700 rounded-lg border border-slate-200 text-sm focus:ring-violet-500 focus:border-violet-500 outline-none">
                            <option>All Products</option>
                            <option>Home & Living</option>
                            <option>Gaming</option>
                            <option>Travel</option>
                            <option>Clearance</option>
                        </select>
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Exclusive Drops Carousel -->
        <section class="mb-20">
            <div class="flex justify-between items-center mb-8">
                <h2 class="text-3xl font-bold text-violet-900 brand-font">Featured Exclusives</h2>
                <div class="flex gap-3">
                    <button onclick="prevSlide()" class="w-12 h-12 rounded-full border border-slate-200 hover:border-slate-900 hover:bg-slate-900 hover:text-white text-slate-900 transition-all flex items-center justify-center"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg></button>
                    <button onclick="nextSlide()" class="w-12 h-12 rounded-full border border-slate-200 hover:border-slate-900 hover:bg-slate-900 hover:text-white text-slate-900 transition-all flex items-center justify-center"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
                </div>
            </div>

            <div id="product-carousel" class="relative overflow-hidden rounded-3xl shadow-2xl shadow-slate-200/50 bg-white">
                <div id="slider-track" class="flex transition-transform duration-700 cubic-bezier(0.2, 0.8, 0.2, 1)">
                    <% exclusiveProducts.forEach(product => { %>
                    <div class="w-full flex-shrink-0">
                        <div class="flex flex-col md:flex-row h-96 slide-card-height group">
                            <!-- Image -->
                            <div class="w-full md:w-1/2 h-64 md:h-full relative overflow-hidden bg-slate-100 cursor-pointer" onclick="openQuickView('<%= product._id %>', '<%= product.name %>', <%= product.price %>, '/uploads/products/<%= product.image %>', '<%= product.description %>','<%= product.stock %>')">
                                <img src="/uploads/products/<%= product.image %>" alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                                <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors duration-500"></div>
                            </div>
                            <!-- Content -->
                            <div class="w-full md:w-1/2 p-8 md:p-16 flex flex-col justify-center bg-white relative">
                                <div class="absolute top-8 right-8">
                                     <span class="inline-block px-3 py-1 bg-violet-100 text-violet-700 text-[10px] font-bold uppercase tracking-widest rounded-full">Limited Drop</span>
                                </div>
                                
                                <div class="mb-8 relative z-10">
                                    <h3 class="text-4xl font-bold text-slate-900 mb-4 brand-font cursor-pointer hover:text-violet-700 transition" onclick="openQuickView('<%= product._id %>', '<%= product.name %>', <%= product.price %>, '/uploads/products/<%= product.image %>', '<%= product.description %>')"><%= product.name %></h3>
                                    <p class="text-slate-500 text-lg leading-relaxed font-light"><%= product.description %></p>
                                </div>
                                <div class="flex flex-wrap items-center gap-6">
                                    <div class="text-2xl  text-red-700 font-bold">₹<%= product.price.toLocaleString("en-IN") %></div>
                                    
                                    <% if (product.stock <= 0) { %>
                                        <div class="px-6 py-3 bg-slate-100 text-slate-400 font-medium rounded-full cursor-not-allowed">Sold Out</div>
                                    <% } else { %>
                                        <button onclick="addToCart('<%= product._id %>','<%= product.name %>',<%= product.price %>,'/uploads/products/<%= product.image %>')" class="px-8 py-3.5 bg-slate-900 hover:bg-violet-600 text-white font-medium rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1">
                                            Add to Cart
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </section>

        <!-- Product Grid -->
        <section id="new-arrivals">
            <div class="flex items-end justify-between mb-10">
                <div>
                    <h2 class="text-3xl font-bold text-violet-900 brand-font">New Arrivals</h2>
                    <p class="text-slate-500 mt-2">Discover the latest in technology and design.</p>
                </div>
                <a href="#" class="hidden md:inline-flex items-center text-sm font-bold text-violet-600 hover:text-violet-800 transition group">
                    View All Collection 
                    <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                <% if (products && products.length > 0) { %>

                <% products.forEach(product => { %>
                <div class="product-card bg-white rounded-2xl border border-slate-100 overflow-hidden group relative"
                    data-name="<%= product.name.toLowerCase() %>"
                    data-description="<%= product.description.toLowerCase() %>">
                    
                    <!-- Image Area -->
                    <div class="relative aspect-[14/15] bg-slate-50 overflow-hidden cursor-pointer" onclick="openQuickView('<%= product._id %>', '<%= product.name %>', <%= product.price %>, '/uploads/products/<%= product.image %>', '<%= product.description %>','<%= product.stock %>')">
                        <img src="/uploads/products/<%= product.image %>" alt="<%= product.name %>"
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                            onerror="this.onerror=null; this.src='https://placehold.co/600x600/f1f5f9/94a3b8?text=Image+Unavailable';"> 
                        
                        <!-- Overlay Gradient -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                        <!-- Actions Overlay -->
                        <div class="absolute top-4 right-4 flex flex-col gap-3 translate-x-10 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300">
                            
                             <button onclick="toggleWishlist(event,'<%= product._id %>', this)"
                                class="absolute top-4 right-4 w-9 h-9 bg-white/90 rounded-full flex items-center justify-center shadow hover:bg-white transition">

                                <svg class="w-5 h-5 wishlist-icon <%= wishlistIds.includes(product._id.toString()) ? 'text-red-500 fill-red-500' : 'text-slate-400 fill-none' %>"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24">

                                    <path stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                                    </path>
                                    
                                </svg>

                            </button>
                        </div>

                        <% if (product.stock <= 0){%>
                        <div class="absolute inset-0 bg-white/80 backdrop-blur-[2px] flex items-center justify-center z-10">
                            <span class="bg-slate-900 text-white px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest shadow-xl">Out of Stock</span>
                        </div>
                        <%}%>
                    </div>

                    <!-- Details -->
                    <div class="p-4">
                        <div class="mb-4">
                            <p class="text-xs text-violet-600 font-bold uppercase  mb-1">New</p>
