<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gadgetique | OTP Verification</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      /* Premium Typography */
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Playfair+Display:wght@400;600;700;800&display=swap");

      :root {
        font-family: "Inter", sans-serif;
      }

       body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #1e293b;
            overflow-x: hidden;
        }

       h3, .brand-font {
            font-family: 'Playfair Display', serif;
        }

      /* Editorial Gradient Text */
      .gradient-text {
            background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

      /* Clean White Card with soft shadow */
      .glass-modern {
        background-color: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
      }

      /* Input field styling (Structure preserved as requested) */
      .input-modern {
        @apply bg-slate-50 text-slate-900 
        border-2 border-black 
        focus:border-violet-500 focus:ring-1 focus:ring-violet-500/30 
        transition duration-150 ease-in-out;
      }

      /* Abstract background elements */
      .bg-blob {
            position: fixed;
            z-index: -1;
            filter: blur(80px);
            opacity: 0.12;
            border-radius: 50%;
        }

      /* Hide number input arrows */
      .otp-input[type="number"]::-webkit-inner-spin-button,
      .otp-input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }

      .otp-input {
        -moz-appearance: textfield;
      }
    </style>
  </head>

  <body class="min-h-screen flex items-center justify-center p-4 relative">
    
    <!-- Background Decoration -->
    <div class="bg-blob w-96 h-96 bg-violet-400 -top-20 -left-20"></div>
    <div class="bg-blob w-96 h-96 bg-fuchsia-400 -bottom-20 -right-20"></div>

    <!-- Transparent Reset Card -->
    <div
      id="reset-card"
      class="glass-modern p-8 sm:p-10 w-full max-w-sm mx-auto rounded-3xl transition-all duration-300"
    >
      <!-- Header -->
      <div class="text-center mb-8">
        <h3 class="text-3xl font-extrabold gradient-text tracking-tight brand-font">
          Verify Access
        </h3>
        <p class="mt-3 text-slate-500 text-sm leading-relaxed" id="otp-message">
          A security code has been sent to your inbox. Please enter the 4 digits below.
        </p>
      </div>

      <!-- Universal Alert System -->
      <% if (query.error) { %>
      <div class="mb-6 p-3 rounded-xl bg-rose-50 border border-rose-100 text-rose-600 text-xs font-medium text-center">
        <%= query.error %>
      </div>
      <% } %> 
      
      <% if (query.success) { %>
      <div class="mb-6 p-3 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-600 text-xs font-medium text-center">
        <%= query.success %>
      </div>
      <% } %>

      <!-- OTP Verification Form -->
      <form id="otp-form" class="space-y-8" action="/auth/verify-otp" method="POST">
        <input type="hidden" name="email" value="<%= email %>" />
        <input type="hidden" name="otp" id="otp-value" />

        <div class="flex justify-center space-x-3" id="otp-inputs">
          <input
            id="otp-1"
            type="text"
            maxlength="1"
            pattern="[0-9]"
            inputmode="numeric"
            required
            class="otp-input input-modern w-14 h-14 text-2xl font-bold text-center rounded-xl border border-slate-300"
          />
          <input
            id="otp-2"
            type="text"
            maxlength="1"
            pattern="[0-9]"
            inputmode="numeric"
            required
            class="otp-input input-modern w-14 h-14 text-2xl font-bold text-center rounded-xl border border-slate-300"
          />
          <input
            id="otp-3"
            type="text"
            maxlength="1"
            pattern="[0-9]"
            inputmode="numeric"
            required
            class="otp-input input-modern w-14 h-14 text-2xl font-bold text-center rounded-xl border border-slate-300"
          />
          <input
            id="otp-4"
            type="text"
            maxlength="1"
            pattern="[0-9]"
            inputmode="numeric"
            required
            class="otp-input input-modern w-14 h-14 text-2xl font-bold text-center rounded-xl border border-slate-300"
          />
        </div>

        <!-- Verify Button -->
        <button
          type="submit"
          id="verify-btn"
          class="w-full flex justify-center py-4 px-4 rounded-xl shadow-lg shadow-violet-200 text-sm font-bold text-white bg-slate-900 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500 transition duration-300 ease-in-out mt-6 disabled:bg-slate-300"
        >
          VERIFY IDENTITY
        </button>

        <!-- Resend Button -->
        <div class="w-full text-center mt-10 pt-6 border-t border-slate-50">
           <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Didn't receive it?</p>
          <a
            href="/auth/resend-otp?email=<%= email %>"
            class="text-sm font-bold text-violet-600 hover:text-violet-800 transition-colors duration-150"
          >
            Resend New Code
          </a>
        </div>
      </form>

      <!-- Back to Login Link -->
      <p class="text-center mt-8">
        <a
          href="/auth/login"
          class="text-[10px] font-bold text-slate-400 uppercase tracking-widest hover:text-slate-600 transition flex items-center justify-center gap-2"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Login
        </a>
      </p>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("otp-form");
        const otpInputs = document.querySelectorAll(".otp-input");
        const otpHiddenInput = document.getElementById("otp-value");

        // Auto focus next box
        otpInputs.forEach((input, index) => {
          input.addEventListener("input", (e) => {
            e.target.value = e.target.value.replace(/[^0-9]/g, ""); // only digits

            if (e.target.value && index < otpInputs.length - 1) {
              otpInputs[index + 1].focus();
            }

            // Move value to hidden input in real-time
            otpHiddenInput.value = Array.from(otpInputs)
              .map((i) => i.value)
              .join("");
          });

          // Move to previous on backspace
          input.addEventListener("keydown", (e) => {
            if (e.key === "Backspace" && !input.value && index > 0) {
              otpInputs[index - 1].focus();
            }
          });

          // Allow pasting full code
          input.addEventListener("paste", (e) => {
            const pastedData = e.clipboardData.getData("text").trim();
            if (/^\d+$/.test(pastedData)) {
              const chars = pastedData.split("");
              otpInputs.forEach((box, i) => (box.value = chars[i] || ""));
              otpHiddenInput.value = chars.join("");
              otpInputs[Math.min(chars.length, otpInputs.length - 1)].focus();
              e.preventDefault();
            }
          });
        });

        // On form submit → ensure 4 digits
        form.addEventListener("submit", (e) => {
          const otp = Array.from(otpInputs)
            .map((i) => i.value.trim())
            .join("");
          otpHiddenInput.value = otp;

          if (otp.length !== otpInputs.length) {
            e.preventDefault();
            // Using a custom message instead of alert for theme consistency
            if(!document.getElementById('validation-hint')) {
                const hint = document.createElement('p');
                hint.id = 'validation-hint';
                hint.className = "text-center text-[10px] font-bold text-rose-500 uppercase tracking-widest mt-4";
                hint.innerText = "Please enter all 4 digits";
                form.appendChild(hint);
            }
          }
        });
      });
    </script>
  </body>
</html>