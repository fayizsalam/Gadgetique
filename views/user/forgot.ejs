<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gadgetique | Forgot Password</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* Professional Typography matching the brand theme */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap');

    body {
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #1e293b;
        overflow-x: hidden;
    }

    h1, h2, h3, .brand-font {
        font-family: 'Playfair Display', serif;
    }

    .gradient-text {
        background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .input-field {
        @apply w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all duration-300 placeholder-slate-400 text-slate-700;
    }

    .btn-primary {
        @apply w-full py-4 bg-slate-900 hover:bg-violet-700 text-white font-medium rounded-xl shadow-lg shadow-violet-900/10 transition-all duration-300 transform active:scale-[0.98];
    }

    /* Abstract background elements */
    .bg-blob {
        position: fixed;
        z-index: -1;
        filter: blur(80px);
        opacity: 0.12;
        border-radius: 50%;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }
  </style>
</head>

<body class="min-h-screen flex flex-col items-center justify-center p-4 md:p-6 relative">
    
    <!-- Background Decoration -->
    <div class="bg-blob w-96 h-96 bg-violet-400 -top-20 -left-20"></div>
    <div class="bg-blob w-96 h-96 bg-fuchsia-400 -bottom-20 -right-20"></div>

    <div class="w-full max-w-md my-auto">
        <!-- Brand Header -->
        <div class="text-center mb-4">
            <a href="/" class="text-4xl font-extrabold tracking-tight gradient-text brand-font mb-2 block">
                Gadgetique.
            </a>
        </div>

        <!-- Forgot Password Card -->
        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-2xl shadow-slate-200/60 border border-slate-100 max-h-[85vh] overflow-y-auto custom-scrollbar">
            
            <div class="text-center mb-6 -mt-2">
                <h2 class="text-2xl font-bold text-violet-900">Reset Access</h2>
                <p class="text-sm text-slate-500 mt-2">We’ll send a secure OTP to your email.</p>
            </div>

            <!-- Alert System -->
            <% if (query.error) { %>
            <div class="mb-5 p-3 rounded-xl bg-rose-50 border border-rose-100 text-rose-600 text-xs font-medium flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span><%= query.error %></span>
            </div>
            <% } %>

            <% if (query.success) { %>
            <div class="mb-5 p-3 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-600 text-xs font-medium flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span><%= query.success %></span>
            </div>
            <% } %>

            <form action="/auth/forgot" method="POST" class="space-y-6">
                <div>
                    <label for="email" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="you@example.com" required
                        class="input-field text-md border border-slate-200 rounded-md w-full h-10" autocomplete="email">
                </div>

                <button type="submit" class="w-full flex items-center justify-center py-3 px-4 border border-slate-200 rounded-xl text-sm font-bold text-slate-600 bg-white hover:bg-violet-500 hover:text-white transition duration-200">
                    Send Security Code
                </button>
            </form>

            <!-- Back to Login -->
            <div class="relative my-8">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-100"></div></div>
                <div class="relative flex justify-center text-[10px] uppercase tracking-widest font-bold text-slate-300">
                    <span class="bg-white px-4">Wait, I remember it</span>
                </div>
            </div>

            <a href="/auth/login" class="w-full flex items-center justify-center py-3 px-4 border border-slate-200 rounded-xl text-xs font-bold text-slate-600 bg-white hover:bg-slate-50 transition duration-200">
                Back to Sign In
            </a>
        </div>

        <!-- Help Footer -->
        <p class="text-center text-[10px] mt-8 text-slate-400 leading-relaxed max-w-[280px] mx-auto uppercase tracking-tighter">
            Having trouble? Please contact our 
            <a href="#" class="underline hover:text-slate-600">Support Concierge</a>.
        </p>
    </div>
</body>
</html>