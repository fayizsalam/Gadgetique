<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gadgetique | My Orders</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom font import */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap');

        :root {
            font-family: 'Inter', sans-serif;
        }

        /* Defining the dark, gradient background for a modern feel */
        .bg-modern-dark {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }

        /* Custom glass effect (Modern, slightly frosted dark glass) */
        .glass-modern {
            /* Slate-800 with 40% opacity */
            background-color: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Custom glass effect for header */
        .bg-glass {
            /* Slate-900 with high opacity for better contrast against background */
            background-color: rgba(17, 24, 39, 0.9);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }


        /* Neon Cyan additions */
        .text-neon-cyan {
            color: #22D3EE;
            /* Cyan 400 */
            text-shadow: 0 0 10px rgba(34, 211, 238, 0.4);
        }

        /* General Card for Order items (more subtle glass) */
        .order-card {
            background-color: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .order-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px rgba(34, 211, 238, 0.15);
        }

        /* Icon styles for the Header */
        .action-icon {
            color: #94A3B8;
            /* Slate 400 */
            transition: color 0.15s;
        }

        .action-icon:hover {
            color: #22D3EE;
            /* Neon Cyan */
        }

        /* Nav Link styles for the Header */
        .nav-link {
            @apply text-sm font-medium px-3 py-2 rounded-lg text-slate-300 transition duration-150;
        }

        .nav-link:hover {
            @apply text-neon-cyan bg-slate-700/50;
        }

        .nav-link.active {
            @apply text-neon-cyan border-b-2 border-neon-cyan font-semibold;
        }
    </style>
</head>

<body class="bg-modern-dark min-h-screen pb-12 flex flex-col items-center justify-start">

    <!-- HEADER - Integrated as requested. Removed sticky positioning. -->
    <header class="z-30 shadow-xl border-b border-slate-700 bg-glass w-full">

        <!-- Top Header Bar (Logo, Actions) -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-4">

            <!-- Logo -->
            <div class="flex-shrink-0">
                <a href="#" class="text-3xl font-extrabold text-neon-cyan tracking-wider">
                    GADGETIQUE
                </a>
            </div>

            <!-- Header (Centered on Desktop) -->
            <!-- Changed justify-start to justify-center and added text-center for centering -->
            <div class="hidden lg:flex flex-grow mx-8 items-center justify-center">
                <div class="text-center">
                    <h1 class="text-xl font-extrabold text-neon-cyan tracking-tight">
                        My Recent Orders
                    </h1>
                    <p class="text-sm text-gray-300">
                        Track your cutting-edge tech from Gadgetique.
                    </p>
                </div>
            </div>


            <!-- Action Icons & Account Info -->
            <div class="flex items-center space-x-2 sm:space-x-4 text-white">

                <!-- Wishlist Icon (All screens) -->
                <button class="action-icon relative" onclick="handleAction('Wishlist')">
                    <!-- Heart Icon -->
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                        </path>
                    </svg>
                </button>

                <!-- NEW: Simple Cart Icon (Mobile Only) -->
                <button class="action-icon relative sm:hidden" onclick="handleAction('Cart')">
                    <!-- Shopping Cart Icon -->
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                        </path>
                    </svg>
                    <!-- Cart Count Badge (3 items in mock cart: 2 of one item + 1 of another) -->
                    <span
                        class="absolute top-0 right-0 inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none text-red-100 transform translate-x-1/2 -translate-y-1/2 bg-cyan-600 rounded-full">3</span>
                </button>

                <!-- Cart Summary (Tablet/Desktop Only - Full Button) -->
                <button
                    class="hidden sm:flex items-center space-x-2 px-3 py-2 rounded-xl bg-slate-700 hover:bg-slate-600 transition duration-150"
                    onclick="handleAction('Cart Summary')">
                    <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z">
                        </path>
                    </svg>
                    <div class="text-sm text-left">
                        <span class="block text-slate-400">Total:</span>
                    </div>
                </button>

                <!-- Account Dropdown (Click to open) -->
                <div class="relative z-40">
                    <button id="accountDropdownButton"
                        class="action-icon flex items-center space-x-1 focus:outline-none group">
                        <!-- User Icon -->
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <!-- Dropdown Arrow -->
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-cyan-400 transition" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7">
                            </path>
                        </svg>
                    </button>

                    <!-- Dropdown Menu -->
                    <div id="accountDropdownMenu" class="hidden absolute right-0 top-7 mt-2 w-40 bg-slate-800 border border-slate-700
                        rounded-lg shadow-xl transition z-50">
                        <a href="/auth/home"
                            class="block px-4 py-2 text-slate-300 hover:text-cyan-400 hover:bg-slate-700 transition">
                            Home
                        </a>
                        <a href="/auth/profile"
                            class="block px-4 py-2 text-slate-300 hover:text-cyan-400 hover:bg-slate-700 transition">
                            Profile
                        </a>
                        <form action="/auth/logout" method="get">
                            <button type="submit"
                                class="w-full text-left px-4 py-2 text-slate-300 hover:text-red-400 hover:bg-slate-700 transition">
                                Logout
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>

        <!-- Mobile View -->
        <div class="lg:hidden text-center px-4 pt-0 pb-4">
            <h1 class="text-2xl font-extrabold text-neon-cyan tracking-tight">
                My Recent Orders
            </h1>
            <p class="mt-1 text-sm text-gray-400">
                Track your cutting-edge tech from Gadgetique.
            </p>
        </div>

    </header>


    <!-- MAIN ORDERS DASHBOARD CONTAINER -->
    <div id="ordersDashboard" class="glass-modern p-6 md:p-10 w-full max-w-7xl mx-auto rounded-xl shadow-2xl mt-12">

        <!-- Orders Summary/Stats Section (Responsive Cards) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="order-card p-5 rounded-lg">
                <p class="text-sm font-medium text-gray-400">Total Orders:</p>
                <p class="text-3xl font-bold text-white mt-1" id="totalOrders"></p>
            </div>
            <!-- UPDATED: Changed label from 'Last 30 Days' to 'Delivered Shipments' -->
            <div class="order-card p-5 rounded-lg">
                <p class="text-sm font-medium text-gray-400">Delivered Shipments:</p>
                <p class="text-3xl font-bold text-white mt-1" id="last30Days"></p>
            </div>
            <div class="order-card p-5 rounded-lg">
                <p class="text-sm font-medium text-gray-400">Pending Shipment:</p>
                <p class="text-3xl font-bold text-yellow-400 mt-1" id="pendingShipment"></p>
            </div>
        </div>

        <!-- Order History Header and Filter -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 border-b border-cyan-700 pb-2">
            <h2 class="text-xl font-semibold text-white mb-2 sm:mb-0">Order History</h2>
            <div class="flex items-center space-x-2 w-full sm:w-auto">
                <label for="statusFilter" class="text-sm text-gray-400 hidden sm:block">Filter by Status:</label>
                <select id="statusFilter" class="py-1 px-3 bg-slate-700 text-slate-300 rounded-lg border border-slate-600 focus:ring-neon-cyan focus:border-neon focus:outline-none text-sm w-full sm:w-auto">
                    <option value="All">All Statuses</option>
                    <option value="Processing">Processing</option>
                    <option value="Shipped">Shipped</option>
                    <option value="Delivered">Delivered</option>
                </select>
            </div>
        </div>

        <!-- Order List Section (Table Structure) -->
        <div class="overflow-x-auto glass-modern rounded-xl shadow-inner">
            <table class="min-w-full divide-y divide-slate-700">
                <thead class="bg-slate-700/70">
                    <tr>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-1/6">
                            Order ID
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-1/12">
                            Date
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-4/12">
                            Items
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-1/6">
                            Total (INR)
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-1/6">
                            Status
                        </th>
                    </tr>
                </thead>
                <tbody id="ordersList" class="divide-y divide-slate-800 bg-slate-900/40">
                    <!-- Order Rows can be updated here -->
                    <tr>
                        <td colspan="5" class="py-8 text-center text-gray-500" id="loadingMessage">
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- End Order List Section -->

    </div>

<script>
    
    // Dropdown toggle logic
    document.addEventListener('click', (e) => {
            const btn = document.querySelector('#accountDropdownButton');
            const menu = document.querySelector('#accountDropdownMenu');
            if (!btn || !menu) return;

            if (btn.contains(e.target)) {
                // Toggle menu visibility
                menu.classList.toggle('hidden');
            } else if (!menu.contains(e.target)) {
                // Close menu if clicking outside
                menu.classList.add('hidden');
            }
        });
</script>
  
</body>

</html>
