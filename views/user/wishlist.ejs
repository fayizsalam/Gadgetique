<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist | Gadgetique Premium Tech</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
            color: #1e293b;
        }

        h1, h2, h3, .brand-font {
            font-family: 'Playfair Display', serif;
        }

        .bg-glass {
            background-color: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
        }

        .gradient-text {
            background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .product-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }

        /* Ticker Animation */
        @keyframes ticker {
            0% { transform: translateX(0%); }
            100% { transform: translateX(-50%); }
        }

        .animate-ticker {
            display: inline-block;
            white-space: nowrap;
            animation: ticker 40s linear infinite;
        }
    </style>
</head>

<body class="antialiased">

    <!-- Promo Bar -->
    <div class="w-full bg-slate-900 overflow-hidden py-2.5 relative z-50">
        <div class="animate-ticker whitespace-nowrap text-[10px] font-bold tracking-[0.2em] text-white/80 uppercase">
            <span>Exclusive Rewards for Members</span>
            <span class="mx-10">•</span>
            <span>Free Express Shipping on Orders Over ₹5,000</span>
            <span class="mx-10">•</span>
            <span>New Drop: Quantum Series Headphones Out Now</span>
            <span class="mx-10">•</span>
        </div>
    </div>

    <!-- Navigation -->
    <header class="sticky top-0 z-40 bg-glass border-b border-slate-100 backdrop-blur-xl">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <a href="/auth/home" class="text-2xl font-extrabold tracking-tight gradient-text brand-font">
                Gadgetique.
            </a>

            <h1 class="text-4xl md:text-4xl font-bold text-slate-900">My Wishlist</h1>

            <div class="flex items-center gap-6">
                <!-- <a href="/auth/home" class="text-sm font-medium text-slate-600 hover:text-violet-600 transition">Shop</a> -->
                <!-- Cart -->
                 <a href="/auth/cart" class="action-icon relative group block">
                    <div class="relative">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                        </svg>
                        <span id="cartBadge" class="absolute -top-0 -right-1 bg-violet-600 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full opacity-0 scale-0 transition-all duration-300">0</span>
                    </div>
                </a>
                <div class="relative z-40 ml-2 group">
                    <!--User Name Button -->
                    <button id="accountDropdownButton"
                        class="flex items-center gap-2 px-1 py-1 rounded-full hover:bg-slate-50 transition duration-200 focus:outline-none ring-2 ring-transparent focus:ring-slate-100">
                        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-100 to-fuchsia-100 flex items-center justify-center text-violet-700 font-bold text-xs shadow-inner">
                             <span><%= user ? user.charAt(0).toUpperCase() : "U" %></span>
                        </div>
                    </button>
                    <!-- Drop down Menu -->
                    <div id="accountDropdownMenu" class="absolute left-0 mt-1 w-48 bg-white border border-slate-100 rounded-2xl shadow-xl py-2 z-50 transform origin-top-right transition-all opacity-0 invisible group-hover:opacity-100 group-hover:visible">
                        <div class="px-5 py-4 border-b border-slate-50">
                             <p class="text-xs text-slate-400 uppercase font-bold tracking-wider mb-1">Signed in as</p>
                             <p class="text-sm font-semibold text-slate-900 truncate"><%= user %></p>
                        </div>
                        <form action="/auth/home" method="get">
                            <button type="submit" class="text-left block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors w-full">My Homepage</button>
                        </form>
                        <!-- <a href="" class="block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors"></a> -->
                         <form action="/auth/profile" method="get">
                            <button type="submit" class="text-left block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors w-full">My Profile</button>
                        </form>
                        <div class="border-t border-slate-50 mt-1"></div>
                        <form action="/auth/logout" method="get">
                            <button type="submit" class="w-full text-left px-5 py-3 text-sm text-rose-500 hover:bg-rose-50 font-medium transition-colors rounded-b-xl">Sign Out</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Header -->
        <div class="flex justify-between gap-4 mb-10 max-w-6xl">
            <div>
                <nav class="flex mb-4 text-xs font-bold uppercase tracking-widest text-slate-400">
                    <a href="/auth/home" class="hover:text-violet-600">Home</a>
                    <span class="mx-2">/</span>
                    <span class="text-slate-900">Wishlist</span>
                </nav>
                
                <p class="text-slate-500 mt-2">You have 
                    <span id="wishCount" class="font-semibold text-violet-600">
                        <%= wishlist ? wishlist.products.length : 0 %>
                    </span> items saved for later.
                </p>
            </div>
          
                <button onclick="addAllToCart()" class="items-end sm:w-auto px-6 py-3 bg-white border border-slate-200 text-slate-900 rounded-xl text-sm font-bold uppercase tracking-widest hover:bg-slate-50 transition shadow-sm">
                Move All to Bag
            </button>
       
            
        </div>

        <!-- Wishlist Grid -->
        <% if (wishlist && wishlist.products.length > 0) { %>

        <div id="wishlistGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

                <% wishlist.products.forEach(item => { %>
                <% if (item.productId) { %>
<div class="product-card bg-white rounded-3xl overflow-hidden border border-slate-100 flex flex-col" data-id="<%= item.productId._id %>">

    <div class="relative aspect-[4/5] overflow-hidden group">
        <img src="/uploads/products/<%= item.productId.image %>" alt="<%= item.productId.name %>"
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                            onerror="this.onerror=null; this.src='https://placehold.co/600x600/f1f5f9/94a3b8?text=Image+Unavailable';"> 
        
        <button onclick="removeItem('<%= item.productId._id %>')" class="absolute top-4 right-4 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-slate-400 hover:text-rose-500 hover:bg-white shadow-sm transition-all duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
    </div>

    <div class="p-6 flex flex-col grow">

        <div class="flex justify-between items-start mb-2">
            <h3 class="font-bold text-slate-900 line-clamp-1">
                <%= item.productId.name %>
            </h3>

            <span class="font-bold text-violet-600 whitespace-nowrap ml-2">
                ₹<%= item.productId.price %>
            </span>
        </div>

        <button onclick="moveToCart('<%= item.productId._id %>')" class="mt-auto w-full py-3 bg-slate-900 text-white text-xs font-bold uppercase tracking-widest rounded-xl hover:bg-violet-700 transition-all">
            Add to Bag
        </button>

    </div>

</div>
                <% } %>
<% }) %>
        </div>

        <% } else { %>

        <!-- Empty State -->
        <div id="emptyState" class="py-32 text-center">
            <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 mb-2">Your wishlist is empty</h2>
            <p class="text-slate-500 mb-8">Save items you like to see them here later.</p>
            <a href="/auth/home" class="inline-block px-10 py-4 bg-slate-900 text-white font-bold uppercase tracking-widest text-xs rounded-full hover:shadow-xl transition-all">
                Continue Shopping
            </a>
        </div>

        <% } %>

        
    </main>

    <!-- Footer -->
    <footer class="bg-slate-950 text-white py-20 mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span class="text-2xl font-extrabold brand-font mb-8 block">Gadgetique.</span>
            <div class="flex flex-wrap justify-center gap-8 text-xs font-bold uppercase tracking-[0.2em] text-slate-500">
                <a href="#" class="hover:text-white transition">Privacy</a>
                <a href="#" class="hover:text-white transition">Terms</a>
                <a href="#" class="hover:text-white transition">Shipping</a>
                <a href="#" class="hover:text-white transition">Returns</a>
            </div>
            <p class="mt-12 text-slate-600 text-sm">© 2026 Gadgetique Premium. All rights reserved.</p>
        </div>
    </footer>

    <script>
        function updateWishCount() {
            const items = document.querySelectorAll('.product-card').length;
            document.getElementById('wishCount').textContent = items;
            
            if (items === 0) {
                document.getElementById('wishlistGrid').classList.add('hidden');
                document.getElementById('emptyState').classList.remove('hidden');
            }
        }

        async function removeItem(id) {
            try {
                const res = await fetch(`/auth/wishlist/remove/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await res.json();
                if (data.success) {
                    const el = document.querySelector(`[data-id="${id}"]`);
                    if (el) {
                        el.style.opacity = '0';
                        el.style.transform = 'scale(0.9)';
                        setTimeout(() => {
                            el.remove();
                            updateWishCount();
                        }, 300);
                    }
                }
            } catch (error) {
                console.error(error);
            }
        }

        async function moveToCart(id) {
            try {
                const res = await fetch("/auth/cart/add", {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: id })
                });
                const data = await res.json();
                if (data.success) {
                    removeItem(id);
                    handleAction("Moved to Cart successfully!");
                }
            } catch (err) {
                console.error(err);
            }
        }

        function addAllToCart() {
            const cards = document.querySelectorAll('.product-card');
            cards.forEach(card => {
                const id = card.getAttribute('data-id');
                if (id) moveToCart(id);
            });
        }


        async function updateCartBadge() {

  try {

    const res = await fetch("/auth/cart/count");
    const data = await res.json();

    const badge = document.getElementById("cartBadge");

    badge.innerText = data.count;

    if (data.count > 0) {
      badge.style.opacity = "1";
      badge.style.transform = "scale(1)";
    } else {
      badge.style.opacity = "0";
      badge.style.transform = "scale(0)";
    }
    

  } catch (error) {
    console.log(error);
  }

}
    </script>
</body>
</html>