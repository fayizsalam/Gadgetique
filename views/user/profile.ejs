<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Account | Gadgetique</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* ===== Base ===== */
    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #f8fafc;
      color: #1e293b;
    }

    h1, h2, h3, h4, .brand-font {
      font-family: 'Playfair Display', serif;
    }

    /* ===== Brand Colors ===== */
    .text-primary { color: #7c3aed; }
    .bg-primary { background-color: #7c3aed; }

    .gradient-text {
      background: linear-gradient(135deg, #7c3aed, #db2777);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* ===== Glass UI ===== */
    .bg-glass {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(14px);
    }

    /* ===== Navbar ===== */
    .glass-nav {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(226, 232, 240, 0.8);
    }

    /* ===== Nav Links ===== */
    .nav-link {
      position: relative;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: #475569;
      border-radius: 1rem;
      transition: all 0.25s ease;
    }

    .nav-link:hover {
      background: #f8fafc;
      color: #7c3aed;
    }

    .nav-link.active-nav {
      background: white;
      color: #7c3aed;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    /* ===== Profile Cards ===== */
    .profile-card {
      background: #ffffff;
      border: 1px solid #f1f5f9;
      border-radius: 1.75rem;
      box-shadow: 0 4px 6px rgba(0,0,0,0.04);
      transition: 0.3s ease;
    }

    /* ===== Inputs ===== */
    .input-field {
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: 0.75rem;
      border: 1px solid #e2e8f0;
      background: #ffffff;
      font-size: 0.875rem;
      transition: all 0.2s ease;
    }

    .input-field:focus {
      outline: none;
      border-color: #7c3aed;
      box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
    }

    .input-field:disabled {
      background: #f8fafc;
      color: #64748b;
      cursor: not-allowed;
    }

    /* ===== Buttons ===== */
    .btn-primary {
      padding: 0.75rem 1.5rem;
      background: #7c3aed;
      color: white;
      font-weight: 700;
      border-radius: 0.75rem;
      transition: 0.25s ease;
    }

    .btn-primary:hover {
      background: #6d28d9;
    }

    /* ===== Drawers ===== */
    .side-drawer {
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .side-drawer.open {
      transform: translateX(0);
    }

    /* ===== Scrollbar ===== */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-thumb {
      background: #e5e7eb;
      border-radius: 999px;
    }
    @keyframes ticker {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

.animate-ticker {
  display: inline-block;
  white-space: nowrap;
  animation: ticker 40s linear infinite;
}
@keyframes slideInToast {
  from {
    transform: translateX(40px);
    opacity: 0;
  }
  to {
    transform: translateX(0px);
    opacity: 1;
  }
}

.animate-slide-in {
  animation: slideInToast 0.35s ease forwards;
}

#accountDropdownMenu {
  transition: all 0.25s ease;
  transform: translateY(10px);
}

.group:hover #accountDropdownMenu {
  transform: translateY(0);
}

  </style>
</head>


<body class="antialiased">

    <!-- Notification Toast -->
    <div id="messageBox" class="fixed top-24 right-5 bg-white shadow-2xl rounded-xl p-4 flex items-center gap-4 transform transition-all duration-300 z-[100] border-l-4 border-violet-600 hidden max-w-sm ring-1 ring-black/5">
        <div>
            <h4 class="font-bold text-sm text-slate-900" id="messageTitle">Notification</h4>
            <p id="messageContent" class="text-xs text-slate-500 mt-1">Action completed.</p>
        </div>
        <button onclick="hideMessage()" class="text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </div>

    <!-- Overlay -->
    <div id="drawerOverlay" class="fixed inset-0 bg-slate-900/40 backdrop-blur-[2px] z-[60] hidden transition-opacity duration-300" onclick="closeAllDrawers()"></div>

    <!-- Cart Drawer -->
    <div id="cartDrawer" class="side-drawer fixed right-0 top-0 h-full w-full max-w-md bg-white z-[70] shadow-2xl flex flex-col">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-white">
            <h3 class="text-xl font-bold text-slate-900 font-serif">
                Shopping Cart
            </h3>
            <button onclick="toggleDrawer('cartDrawer')" class="p-2 rounded-full hover:bg-slate-50 transition">
                <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div id="cartItemsContainer" class="flex-grow overflow-y-auto p-6 space-y-4">
            <div class="text-center py-24 flex flex-col items-center justify-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                </div>
                <p class="text-slate-500 font-medium">Your cart is empty</p>
                <button onclick="closeAllDrawers()" class="mt-4 text-violet-600 text-sm font-semibold hover:underline">Start Shopping</button>
            </div>
        </div>

        <div class="p-6 bg-slate-50 border-t border-slate-100">
            <div class="flex justify-between items-center mb-6">
                <span class="text-slate-500 font-medium">Subtotal</span>
                <span id="cartTotalDisplay" class="text-2xl font-bold text-slate-900 brand-font">₹0.00</span>
            </div>
            <button onclick="handleAction('Checkout')" class="w-full py-4 bg-slate-900 hover:bg-violet-700 text-white font-medium rounded-xl shadow-lg shadow-violet-900/10 transition-all duration-300 transform active:scale-[0.98]">
                Proceed to Checkout
            </button>
        </div>
    </div>

    <!-- Wishlist Drawer -->
    <div id="wishlistDrawer" class="side-drawer fixed right-0 top-0 h-full w-full max-w-md bg-white z-[70] shadow-2xl flex flex-col">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center">
            <h3 class="text-xl font-bold text-slate-900 font-serif">
                Your Wishlist
            </h3>
            <button onclick="toggleDrawer('wishlistDrawer')" class="p-2 rounded-full hover:bg-slate-50 transition">
                <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div id="wishlistItemsContainer" class="flex-grow overflow-y-auto p-6 space-y-4">
            <div class="text-center py-24 text-slate-400">No items saved yet.</div>
        </div>

        <div class="p-6 bg-slate-50 border-t border-slate-100">
            <button onclick="closeAllDrawers()" class="w-full py-4 border border-slate-200 text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 font-medium rounded-xl transition-all">
                Continue Shopping
            </button>
        </div>
    </div>


    <!-- Navigation -->
    <header class="sticky top-0 z-30 bg-glass border-b border-slate-100/50 backdrop-blur-xl transition-all duration-300">

        <!-- PROMO BAR -->
        <div class="w-full bg-gradient-to-r from-violet-900 via-indigo-900 to-slate-900 overflow-hidden py-3 cursor-pointer relative z-40" onclick="handleAction('Comming Soon...')">
            <div class="animate-ticker whitespace-nowrap">
                <div class="px-4 text-[11px] font-bold tracking-[0.2em] text-white/90 flex items-center gap-16 uppercase">
                    <span>Free Global Shipping on Orders Over ₹5,000</span>
                    <span class="text-white/30">•</span>
                    <span>Cyber Week: Up to 40% Off Select Hardware</span>
                    <span class="text-white/30">•</span>
                    <span>Use Code "WELCOME2026" for Extra Discount</span>
                    <span class="text-white/30">•</span>
                    <span>New Arrivals: The Future is Here</span>
                    <span class="text-white/30">•</span>
                    <span>Join the Gadgetique Elite Club</span>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between gap-8">

            <div class="flex-shrink-0">
                <a href="#" class="text-3xl font-extrabold tracking-tight gradient-text brand-font">
                    Gadgetique.
                </a>
            </div>
              

            <!-- Icons -->
            <div class="flex items-center gap-3">

                <!-- Wishlist -->
                <button class="action-icon relative group" onclick="toggleDrawer('wishlistDrawer')">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    <span id="wishBadge" class="absolute top-0 right-0 bg-rose-500 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full opacity-0 scale-0 transition-all duration-300">0</span>
                </button>

                <!-- Cart -->
                <button
                    class="action-icon relative group"
                    onclick="toggleCart()">
                    <div class="relative">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                        </svg>
                        <span id="cartBadge" class="absolute -top-1 -right-1 bg-violet-600 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full opacity-0 scale-0 transition-all duration-300">0</span>
                    </div>
                </button>

                <div class="relative z-40 ml-2 group">
                     <!--User Name Button -->
                    <button id="accountDropdownButton"
                        class="flex items-center gap-2 px-1 py-1 rounded-full hover:bg-slate-50 transition duration-200 focus:outline-none ring-2 ring-transparent focus:ring-slate-100">
                        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-100 to-fuchsia-100 flex items-center justify-center text-violet-700 font-bold text-xs shadow-inner">
                             <span><%= user.charAt(0).toUpperCase() %></span>
                           
                        </div>
                    </button>
                    <!-- Drop down Menu -->
                    <div id="accountDropdownMenu" class="absolute right-0 mt-3 w-56 bg-white border border-slate-100 rounded-2xl shadow-xl py-2 z-50 transform origin-top-right transition-all opacity-0 invisible group-hover:opacity-100 group-hover:visible">
                        <div class="px-5 py-4 border-b border-slate-50">
                             <p class="text-xs text-slate-400 uppercase font-bold tracking-wider mb-1">Signed in as</p>
                             <p class="text-sm font-semibold text-slate-900 truncate"><%= user %></p>
                          
                        </div>
                        <a href="/auth/home" class="block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors">Homepage</a>
                        <a href="/auth/orders" class="block px-5 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-violet-700 transition-colors">Order History</a>
                        <div class="border-t border-slate-50 mt-1"></div>
                        <form action="/auth/logout" method="get">
                            <button type="submit" class="w-full text-left px-5 py-3 text-sm text-rose-500 hover:bg-rose-50 font-medium transition-colors rounded-b-xl">Sign Out</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col lg:flex-row gap-12">
            
            <!-- Sidebar -->
            <aside class="w-full lg:w-72 shrink-0">
                <div class="sticky top-32 space-y-8">
                    <div>
                        <h2 class="text-2xl font-bold brand-font text-slate-900 mb-6 px-2">Settings</h2>
                        <nav class="space-y-1">
                            <a href="#personal" class="nav-link flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-slate-500 hover:bg-slate-50 transition-all">
                                <div class="nav-icon w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center transition-all">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                </div>
                                Personal Info
                            </a>
                            <a href="#shipping" class="nav-link flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-slate-500 hover:bg-slate-50 transition-all">
                                <div class="nav-icon w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center transition-all">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                                </div>
                                Shipping Addresses
                            </a>
                            <a href="#payment" class="nav-link flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-slate-500 hover:bg-slate-50 transition-all">
                                <div class="nav-icon w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center transition-all">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                                </div>
                                Payment Methods
                            </a>
                        </nav>
                    </div>

                    <div class="p-6 bg-slate-900 rounded-[2rem] text-white shadow-xl">
                        <p class="text-[10px] font-black text-violet-400 uppercase tracking-widest mb-2">Member Pro</p>
                        <p class="text-sm text-slate-300 leading-relaxed mb-4">You have 2,450 points ready to redeem.</p>
                        <button class="w-full py-2.5 bg-violet-600 text-white text-xs font-bold rounded-xl hover:bg-violet-700 transition">View Rewards</button>
                    </div>
                </div>
            </aside>

            <!-- Dashboard Content -->
            <div class="flex-1 space-y-16">
                
                <!-- Personal Details -->
                <section id="personal" class="scroll-mt-32">

                    <div class="mb-5">
                <h3 class="text-3xl font-bold brand-font text-slate-900">Personal Information</h3>
                <p class="text-sm text-slate-500 mt-1">Manage your basic account identity and contact details.</p>
               </div>

                    <div class="profile-card rounded-3xl p-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="md:col-span-2 flex items-center gap-6 pb-6 border-b border-slate-50">
                                
                                <div class="w-20 h-20 rounded-full bg-violet-100 flex items-center justify-center text-violet-600 font-bold text-2xl">
                                    <%=  user ? user.trim().split(/\s+/).map(w => w[0]).join('').toUpperCase(): '??'%></div>
                                <div>
                                    <h4 id="profileDisplayName" class="font-bold text-slate-900 text-lg"><%= user %></h4>
                                    <button class="text-xs font-bold text-violet-600 hover:underline">Change Profile Photo</button>
                                </div>
                            </div>
                            <!-- Name -->
                             <form action="/auth/profile/editProfile-personal" method="post">
                            <div class="space-y-2">
                                <label class="section-label">Full Name</label>
                                <input type="text" id="personalName" name="username" value="<%= user %>" class="input-field profile-input" disabled>
                            </div>
                            <!-- Email -->
                            <div class="space-y-2 mt-4">
                                <label class="section-label ">Email Address</label>
                                <input type="email" id="personalEmail" name="email" value="<%= email %>" class="input-field profile-input" disabled>
                            </div>
                            <div class="flex items-center justify-between mt-8">
                            <button type="button" id="editProfileBtn" onclick="toggleProfileEdit()" class="px-4 py-2 bg-slate-50 text-slate-900 rounded-xl text-sm font-bold hover:bg-slate-100 transition border border-slate-200">
                            Edit Profile
                            </button>
                        <div id="profileActionArea" class=" hidden">
                            <button type="submit" class="btn-primary">Save Profile</button>
                        </div>
                        </form>
                    </div>
                    
                </section>

                <!-- Shipping Addresses -->
                <section id="shipping" class="scroll-mt-32">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h3 class="text-3xl font-bold brand-font text-slate-900">Shipping Addresses</h3>
                            <p class="text-sm text-slate-500 mt-1">Primary and secondary delivery locations.</p>
                        </div>
                    </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <!-- Add New Address Card (Always Show) -->
    <div onclick="<%= addresses && addresses.length >= 3 ? '' : 'openAddModal()' %>"
        class="profile-card rounded-3xl p-6 border-dashed border-2 flex flex-col items-center justify-center text-center py-10 
        <%= addresses && addresses.length >= 3 ? 'opacity-40 cursor-not-allowed' : 'opacity-70 hover:opacity-100 cursor-pointer' %>">

        <div class="w-14 h-14 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
        </div>
        <span class="text-sm font-bold text-slate-600">
            <%= addresses && addresses.length >= 3 ? "Max 3 Addresses" : "Add Address" %>
        </span>
    </div>




  <!-- Address Cards -->
  <% if (addresses && addresses.length > 0) { %>
    <% addresses.slice(0,3).forEach((addr, index) => { %>

      <div class="profile-card rounded-3xl p-6 relative border border-slate-200">

        <!-- Default Badge -->
        <% if (addr.isDefault) { %>
          <span class="absolute top-4 right-4 px-3 py-1 bg-violet-600 text-white text-[10px] font-black uppercase tracking-widest rounded-full shadow-md">
            Default
          </span>
        <% } %>

        <h4 class="font-bold text-slate-900 mb-2 uppercase">
          <%= addr.AddressType %>
        </h4>

        <p class="text-sm text-slate-600 leading-relaxed">
          <%= addr.BuildingName %>, <%= addr.street %><br>
          <%= addr.city %>, <%= addr.state %> - <%= addr.zip %>
        </p>

        <div class="mt-6 flex gap-4 pt-4 border-t border-slate-100 text-sm">

          <!-- Edit -->
          <button onclick="openEditModal(<%= index %>)"
            class="text-xs font-bold text-violet-600 hover:text-violet-800 transition">
            Edit
          </button>

          <!-- Remove -->
          <form action="/auth/profile/remove-address" method="POST">
  <input type="hidden" name="addressId" value="<%= addr._id %>">
  <button type="submit" class="text-xs font-bold text-rose-500">Remove</button>
</form>


          <!-- Set Default -->
          <% if (!addr.isDefault) { %>
            <form action="/auth/profile/set-default" method="POST">
  <input type="hidden" name="addressId" value="<%= addr._id %>">
  <button type="submit" class="text-xs font-bold text-emerald-600">Set as Default</button>
</form>

          <% } %>

        </div>

      </div>

    <% }) %>
  <% } %>

</div>

                </section>

                <!-- Payment Methods -->
                <section id="payment" class="scroll-mt-32">
                    <div class="mb-8">
                        <h3 class="text-3xl font-bold brand-font text-slate-900">Payment Methods</h3>
                        <p class="text-sm text-slate-500 mt-1">Manage your credit and debit cards.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="profile-card rounded-[2rem] bg-slate-900 p-8 text-white relative overflow-hidden">
                            <div class="absolute -right-12 -top-12 w-48 h-48 bg-violet-600/20 rounded-full blur-3xl"></div>
                            <div class="relative z-10 flex flex-col h-full">
                                <div class="flex justify-between mb-12">
                                    <span class="text-lg italic font-bold tracking-tighter brand-font">VISA</span>
                                    <svg class="w-8 h-8 text-slate-700" fill="currentColor" viewBox="0 0 24 24"><path d="M2 10V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5H2zm0 4v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5H2zm4 2.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/></svg>
                                </div>
                                <p class="text-lg tracking-[0.2em] mb-8">•••• •••• •••• 4242</p>
                                <div class="mt-auto flex justify-between items-end">
                                    <div>
                                        <p class="text-[8px] font-bold text-slate-500 uppercase tracking-widest mb-1">Holder</p>
                                        <p class="text-xs font-bold uppercase tracking-wider">John Doe</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-[8px] font-bold text-slate-500 uppercase tracking-widest mb-1">Expires</p>
                                        <p class="text-xs font-bold">12/28</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="profile-card rounded-3xl p-8 bg-slate-50 border-2 border-dashed">
                            <h4 class="text-sm font-bold text-slate-900 mb-6 uppercase tracking-wider">Add New Card</h4>
                            <div class="space-y-4">
                                <input type="text" placeholder="Card Number" class="input-field">
                                <div class="grid grid-cols-2 gap-4">
                                    <input type="text" placeholder="MM/YY" class="input-field">
                                    <input type="password" placeholder="CVV" class="input-field">
                                </div>
                                <button class="w-full py-3 bg-slate-900 text-white font-bold rounded-xl text-xs hover:bg-slate-800 transition">Save Card</button>
                            </div>
                        </div>
                    </div>
                </section>

                <hr class="border-slate-100">

                <section class="p-8 bg-rose-50 rounded-3xl border border-rose-100 flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <div>
                        <h3 class="text-xl font-bold brand-font text-rose-900">Security & Account</h3>
                        <p class="text-sm text-rose-700/60 font-medium">Manage your password or close your account.</p>
                    </div>
                    <button class="px-5 py-2.5 bg-white text-rose-600 font-bold text-xs rounded-xl border border-rose-200 hover:bg-rose-100 transition">Reset Password</button>
                </section>
            </div>
        </div>
    </main>

    <!-- Edit Address Modal -->
    <div id="editAddressModal" class="fixed inset-0 z-[60] hidden items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-[2.5rem] shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
            <div class="p-8">
                <div class="flex justify-between items-center mb-6">
                    <h3 id="modalTitle" class="text-2xl font-bold brand-font text-slate-900">
                    Edit Address</h3>
                    <button onclick="closeEditModal()" class="text-slate-400 hover:text-slate-600 p-2">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                
                <form action="/auth/profile/editProfile-shipping" method="POST">
                    <input type="hidden" name="addressId" id="addressId">
                    <div class="">
                        <div class="mb-2">
                            <label class="section-label">Address Type</label>
                            <select name="AddressType" class="input-field mb-3" required>
                              <option value="Home">Home</option>
                              <option value="Office">Office</option>
                            </select>
                        </div>
                        <div class="">
                            <label class="section-label">BuildingName</label>
                            <input type="text" name="BuildingName" class="input-field mb-3" required>
                        </div>
                        <div class="">
                          <label class="section-label">Street</label>
                          <input type="text" name="street" class="input-field mb-3" required >
                        </div>
                        <div class="space-y">
                          <label class="section-label">City</label>
                          <input type="text" name="city" class="input-field mb-3" required >
                        </div>
                        <div class="space-y">
                          <label class="section-label">State</label>
                          <input type="text" name="state" class="input-field mb-3" required >
                        </div>
                        <div class="space-y-1">
                          <label class="section-label">ZIP</label>
                          <input type="text" name="zip" class="input-field mb-3" required>
                        </div>
                        <div class="flex items-center gap-3 pt-4">
                          <button type="submit" class="flex-1 btn-primary">Save Changes</button>
                          <button type="button" onclick="closeEditModal()"
                            class="flex-1 px-6 py-3 bg-slate-50 text-slate-600 font-bold rounded-xl hover:bg-slate-100 transition">
                            Cancel
                          </button>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <footer class="bg-white border-t border-slate-100 py-16">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <h4 class="text-xl font-bold brand-font text-slate-900 mb-2">Gadgetique.</h4>
            <p class="text-[10px] text-slate-300 font-bold uppercase tracking-[0.2em]">&copy; 2026 Gadgetique Global Store</p>
        </div>
    </footer>

     <!-- Toast -->
    <div id="toast-container"
     class="fixed top-5 right-5 z-[100] space-y-3">
    </div>
 <script>
    const addressData = <%- JSON.stringify(addresses || []) %>;

  /* ===============================
     GLOBAL STATE
  =============================== */
  let cart = [];
  let wishlist = [];

  /* ===============================
     DRAWERS
  =============================== */
  function toggleDrawer(id) {
    const drawer = document.getElementById(id);
    const overlay = document.getElementById('drawerOverlay');

    document.querySelectorAll('.side-drawer').forEach(d => {
      if (d.id !== id) d.classList.remove('open');
    });

    const isOpen = drawer.classList.toggle('open');
    overlay.classList.toggle('hidden', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : 'auto';
  }

  function closeAllDrawers() {
    document.querySelectorAll('.side-drawer').forEach(d => d.classList.remove('open'));
    document.getElementById('drawerOverlay').classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  function toggleCart() {
    toggleDrawer('cartDrawer');
  }

  /* ===============================
     WISHLIST
  =============================== */
  function toggleWishlist(id, name, price, img) {
    const index = wishlist.findIndex(i => i.id === id);

    if (index > -1) {
      wishlist.splice(index, 1);
    } else {
      wishlist.push({ id, name, price, img });
    }
    updateWishlistUI();
  }

  function updateWishlistUI() {
    const container = document.getElementById('wishlistItemsContainer');
    const badge = document.getElementById('wishBadge');

    badge.textContent = wishlist.length;
    badge.style.opacity = wishlist.length ? '1' : '0';
    badge.style.transform = wishlist.length ? 'scale(1)' : 'scale(0)';

    if (!wishlist.length) {
      container.innerHTML = `<div class="text-center py-24 text-slate-400">No items saved yet.</div>`;
      return;
    }

    container.innerHTML = wishlist.map(item => `
      <div class="flex gap-4 items-center bg-white p-3 rounded-xl border">
        <img src="${item.img}" class="w-16 h-16 rounded-lg object-cover">
        <div class="flex-1">
          <h4 class="font-bold text-sm">${item.name}</h4>
          <p class="text-violet-600 text-sm">₹${item.price}</p>
        </div>
        <button onclick="addToCart('${item.id}', '${item.name}', ${item.price}, '${item.img}')" class="text-violet-600">+</button>
      </div>
    `).join('');
  }

 
  /* ===============================
    Sysytem Notification
  =============================== */
        function handleAction(action) {
            const box = document.getElementById('messageBox');
            const content = document.getElementById('messageContent');
            const title = document.getElementById('messageTitle');
            
            title.innerText = "System Notification";
            content.innerText = `${action}`;
            
            box.classList.remove('hidden');
            box.classList.add('flex');
            box.classList.add('translate-y-2');
            
            setTimeout(() => {
                 box.classList.remove('translate-y-2');
                 hideMessage();
            }, 3000);
        }

        function hideMessage() {
            const box = document.getElementById('messageBox');
            box.classList.add('hidden');
            box.classList.remove('flex');
        }
  /* ===============================
     CART
  =============================== */
  function addToCart(id, name, price, img) {
    const existing = cart.find(i => i.id === id);
    if (existing) existing.qty++;
    else cart.push({ id, name, price, img, qty: 1 });
    updateCart();
  }

  function removeFromCart(id) {
    cart = cart.filter(i => i.id !== id);
    updateCart();
  }

  function updateQty(id, delta) {
    const item = cart.find(i => i.id === id);
    if (!item) return;
    item.qty += delta;
    if (item.qty <= 0) removeFromCart(id);
    else updateCart();
  }

  function updateCart() {
    const container = document.getElementById('cartItemsContainer');
    const totalDisplay = document.getElementById('cartTotalDisplay');
    const badge = document.getElementById('cartBadge');

    if (!cart.length) {
      container.innerHTML = `<p class="text-center text-slate-500 mt-20">Your cart is empty</p>`;
      totalDisplay.textContent = '₹0.00';
      badge.style.opacity = '0';
      badge.style.transform = 'scale(0)';
      return;
    }

    let total = 0;
    badge.textContent = cart.reduce((a, b) => a + b.qty, 0);
    badge.style.opacity = '1';
    badge.style.transform = 'scale(1)';

    container.innerHTML = cart.map(item => {
      const sub = item.price * item.qty;
      total += sub;
      return `
        <div class="flex gap-4 bg-white p-3 rounded-xl border">
          <img src="${item.img}" class="w-20 h-20 rounded-lg object-cover">
          <div class="flex-1">
            <h4 class="font-bold text-sm">${item.name}</h4>
            <p class="text-xs text-slate-500">₹${item.price}</p>
            <div class="flex gap-2 mt-2">
              <button onclick="updateQty('${item.id}', -1)">-</button>
              <span>${item.qty}</span>
              <button onclick="updateQty('${item.id}', 1)">+</button>
            </div>
          </div>
          <button onclick="removeFromCart('${item.id}')" class="text-rose-500">✕</button>
        </div>
      `;
    }).join('');

    totalDisplay.textContent = `₹${total.toLocaleString('en-IN')}`;
  }

  /* ===============================
     PROFILE EDIT
  =============================== */
  let isProfileEditing = false;

// store original values (for cancel)
let originalProfile = {};

function toggleProfileEdit() {
  const editBtn = document.getElementById("editProfileBtn");
  const inputs = document.querySelectorAll(".profile-input");
  const actionArea = document.getElementById("profileActionArea");

  if (!isProfileEditing) {
    // entering edit mode → save original values
    originalProfile = {};
    inputs.forEach(input => {
      originalProfile[input.id] = input.value;
      input.disabled = false;
    });

    editBtn.textContent = "Cancel";
    actionArea.classList.remove("hidden");
  } else {
    // cancelling edit → restore values
    inputs.forEach(input => {
      input.value = originalProfile[input.id];
      input.disabled = true;
    });

    editBtn.textContent = "Edit Profile";
    actionArea.classList.add("hidden");
  }

  isProfileEditing = !isProfileEditing;
}

/* ===============================
    // --- Account Dropdown Toggle ---
  =============================== */
  /* ===============================
     ADDRESS MODAL
  =============================== */
  
  const modal = document.getElementById('editAddressModal');

function openAddModal() {
  document.getElementById("modalTitle").innerText = "Add New Address";

  document.getElementById("addressId").value = ""; // ✅ empty for new address

  document.querySelector("select[name='AddressType']").value = "Home";
  document.querySelector("input[name='BuildingName']").value = "";
  document.querySelector("input[name='street']").value = "";
  document.querySelector("input[name='city']").value = "";
  document.querySelector("input[name='state']").value = "";
  document.querySelector("input[name='zip']").value = "";

  modal.classList.remove("hidden");
  modal.classList.add("flex");
  document.body.style.overflow = "hidden";
}



function openEditModal(index) {
  document.getElementById("modalTitle").innerText = "Edit Address";

  const addr = addressData[index];

  document.getElementById("addressId").value = addr._id; // ✅ important

  document.querySelector("select[name='AddressType']").value = addr.AddressType;
  document.querySelector("input[name='BuildingName']").value = addr.BuildingName;
  document.querySelector("input[name='street']").value = addr.street;
  document.querySelector("input[name='city']").value = addr.city;
  document.querySelector("input[name='state']").value = addr.state;
  document.querySelector("input[name='zip']").value = addr.zip;

  modal.classList.remove("hidden");
  modal.classList.add("flex");
  document.body.style.overflow = "hidden";
}




function closeEditModal() {
  modal.classList.add('hidden');
  modal.classList.remove('flex');
  document.body.style.overflow = 'auto';
}

function setAsDefault() {
  const btn = document.getElementById("defaultBtn");

  // hide the button after clicking
  btn.classList.add("hidden");

  // optional toast
  showToast("Address set as default!", "success");
}


  modal.addEventListener('click', e => {
    if (e.target === modal) closeEditModal();
  });

  /* ===============================
     SCROLL SPY
  =============================== */
  const sections = document.querySelectorAll('section');
  const navLinks = document.querySelectorAll('.nav-link');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(s => {
      if (pageYOffset >= s.offsetTop - 160) current = s.id;
    });

    navLinks.forEach(l => {
      l.classList.toggle('active-nav', l.getAttribute('href').includes(current));
    });
  });


   //Toast
  function showToast(message, type = "success", duration = 4000) {
    const toast = document.createElement("div");

    const colors = {
      success: "bg-green-600",
      error: "bg-red-600",
      warning: "bg-yellow-500",
      info: "bg-blue-600"
    };

    toast.className = `
      flex items-start gap-3 px-4 py-3 rounded-xl shadow-lg text-white
      ${colors[type]}
      animate-slide-in
    `;

    toast.innerHTML = `
      <div class="flex-1 text-sm font-medium">${message}</div>
      <button class="text-white/80 hover:text-white text-lg leading-none">&times;</button>
    `;

    // Close button
    toast.querySelector("button").onclick = () => {
      toast.remove();
    };

    document.getElementById("toast-container").appendChild(toast);

    // Auto remove
    setTimeout(() => {
  toast.classList.add("opacity-0");
  toast.style.transition = "opacity 0.3s ease";
  setTimeout(() => toast.remove(), 300);
}, duration);

  }

  const params = new URLSearchParams(window.location.search);

  if (params.get("success")) {
    showToast(params.get("success"), "success");
  }

  if (params.get("error")) {
    showToast(params.get("error"), "error");
  }
</script>


</body>
</html>