<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gadgetique | Reset Password</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* Professional Typography */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap');

    body {
      font-family: 'Inter', sans-serif;
      background-color: #ffffff;
      color: #1e293b;
      overflow-x: hidden;
    }

    h3, .brand-font {
      font-family: 'Playfair Display', serif;
    }

    .gradient-text {
      background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* Premium card styling */
    .glass-modern {
      background-color: #ffffff;
      border: 1px solid rgba(0, 0, 0, 0.05);
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
    }

    .input-modern {
      @apply bg-slate-50 text-slate-900 border border-black focus:border-violet-500 focus:ring-1 focus:ring-violet-500 placeholder-slate-400 transition duration-150 ease-in-out;
    }

    /* Abstract background elements */
    .bg-blob {
      position: fixed;
      z-index: -1;
      filter: blur(80px);
      opacity: 0.12;
      border-radius: 50%;
    }
  </style>
</head>

<body class="min-h-screen flex items-center justify-center p-4 relative">

  <!-- Decorative Blobs -->
  <div class="bg-blob w-96 h-96 bg-violet-400 -top-20 -left-20"></div>
  <div class="bg-blob w-96 h-96 bg-fuchsia-400 -bottom-20 -right-20"></div>

  <div class="glass-modern p-8 sm:p-10 w-full max-w-sm mx-auto rounded-3xl relative z-10">
    <div class="text-center mb-8">
      <h3 class="text-4xl font-extrabold gradient-text tracking-tight brand-font mb-2">Gadgetique.</h3>
      <p class="text-slate-500 text-sm font-medium uppercase tracking-widest">Reset Your Password</p>
    </div>

    <!-- Universal Alert System -->
    <% if (query.error) { %>
    <div class="mb-6 p-3 rounded-xl bg-rose-50 border border-rose-100 text-rose-600 text-xs font-medium text-center">
      <%= query.error %>
    </div>
    <% } %> 
    
    <% if (query.success) { %>
    <div class="mb-6 p-3 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-600 text-xs font-medium text-center">
      <%= query.success %>
    </div>
    <% } %>

    <form action="/auth/reset" method="POST" class="space-y-5">
      <input type="hidden" name="email" value="<%= email %>" />
      
      <div>
        <label for="password" class="block text-[10px] font-bold text-slate-400 uppercase tracking-[0.15em] mb-2 px-1">New Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required
          class="input-modern w-full px-4 py-3 rounded-xl text-sm border border-black" autocomplete="new-password">
      </div>

      <div>
        <label for="confirm-password" class="block text-[10px] font-bold text-slate-400 uppercase tracking-[0.15em] mb-2 px-1">Confirm Password</label>
        <input type="password" id="confirm-password" name="confirmPassword" placeholder="••••••••" required
          class="input-modern w-full px-4 py-3 rounded-xl text-sm border border-black" autocomplete="new-password">
      </div>

      <button type="submit"
        class="w-full py-4 px-4 rounded-xl bg-slate-900 hover:bg-violet-700 text-white text-xs font-bold uppercase tracking-widest shadow-lg shadow-violet-900/10 transition duration-300 transform active:scale-[0.98] mt-4">
        Update Password
      </button>
    </form>

    <div class="text-center mt-8 pt-6 border-t border-slate-50">
      <a href="/auth/login" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest hover:text-violet-600 transition flex items-center justify-center gap-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Login
      </a>
    </div>
  </div>

</body>
</html>