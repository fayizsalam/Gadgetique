<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gadgetique | Join the Collection</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Professional Typography matching the homepage/login */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #1e293b;
            /* Ensure the body doesn't scroll if we don't want it to, 
               but allow content to be reached */
            overflow-x: hidden;
        }

        h1, h2, h3, .brand-font {
            font-family: 'Playfair Display', serif;
        }

        .gradient-text {
            background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .input-field {
            @apply w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all duration-300 placeholder-slate-400 text-slate-700;
        }

        .btn-primary {
            @apply w-full py-4 bg-slate-900 hover:bg-violet-700 text-white font-medium rounded-xl shadow-lg shadow-violet-900/10 transition-all duration-300 transform active:scale-[0.98];
        }

        /* Abstract background elements */
        .bg-blob {
            position: fixed;
            z-index: -1;
            filter: blur(80px);
            opacity: 0.12;
            border-radius: 50%;
        }
        
        /* Custom scrollbar for the card if it overflows */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col items-center justify-center p-4 md:p-6 relative">

    <!-- Notification Toast -->
    <div id="messageBox" class="fixed top-24 right-5 bg-white shadow-2xl rounded-xl p-4 flex items-center gap-4 transform transition-all duration-300 z-50 border-l-4 border-violet-600 hidden max-w-sm ring-1 ring-black/5">
        <div>
            <h4 class="font-bold text-sm text-slate-900" id="messageTitle">Notification</h4>
            <p id="messageContent" class="text-xs text-slate-500 mt-1">Action completed.</p>
        </div>
        <button onclick="hideMessage()" class="text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </div>
    
    <!-- Background Decoration -->
    <div class="bg-blob w-96 h-96 bg-violet-400 -top-20 -left-20"></div>
    <div class="bg-blob w-96 h-96 bg-fuchsia-400 -bottom-20 -right-20"></div>

    <!-- Main Wrapper with vertical scrolling capability for small viewports -->
    <div class="w-full max-w-md my-auto">
        <!-- Brand Header -->
        <div class="text-center mb-4">
            <a href="/" class="text-4xl font-extrabold tracking-tight gradient-text brand-font mb-2 block">
                Gadgetique.
            </a>
        </div>

        <!-- Signup Card -->
        <div class="bg-white rounded-3xl p-6 md:p-8 shadow-2xl shadow-slate-200/60 border border-slate-100 max-h-[85vh] overflow-y-auto custom-scrollbar">

            <!-- Title - Margin Top Decreased -->
            <div class="text-center mb-4 -mt-2">
                <h2 class="text-2xl font-bold text-violet-900">Create Account</h2>
                <p class="text-xs text-slate-500 mt-1">Join our exclusive community of enthusiasts</p>
            </div>
            
            <!-- Alert System -->
            <% if (query.error) { %>
            <div class="mb-5 p-3 rounded-xl bg-rose-50 border border-rose-100 text-rose-600 text-xs font-medium flex items-center gap-3 animate-in fade-in slide-in-from-top-2 duration-300">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span><%= query.error %></span>
            </div>
            <% } %>

            <form action="/auth/signup" method="post" class="space-y-4">
                <!-- Username -->
                <div>
                    <label for="username" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Username</label>
                    <input type="text" id="username" name="username" placeholder="gadget_fan" required class="input-field text-sm w-full border border-slate-200">
                </div>

                <!-- Email -->
                <div>
                    <label for="email" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="name@example.com" required class="input-field text-sm w-full border border-slate-200 ">
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Password</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required class="input-field text-sm w-full border border-slate-200 ">
                </div>

                <!-- Confirm Password -->
                <div>
                    <label for="confirmPassword" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required class="input-field text-sm w-full border border-slate-200 ">
                </div>

                <!-- Signup Button -->
                <button type="submit" class="w-full flex items-center justify-center py-3 px-4 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-violet-700 transition duration-300 shadow-lg shadow-slate-200 mt-2">
                    Create Account
                </button>
            </form>

            <!-- OR Divider -->
            <div class="relative my-4">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-100"></div></div>
                <div class="relative flex justify-center text-[10px] uppercase tracking-widest font-bold text-slate-300">
                    <span class="bg-white px-4">Already a member?</span>
                </div>
            </div>

            <!-- Login Redirect -->
            <a href="/auth/login" class="w-full flex items-center justify-center py-3 px-4 border border-slate-200 rounded-xl text-xs font-bold text-slate-600 bg-white hover:bg-slate-50 transition duration-200">
                Sign In Instead
            </a>
        </div>

        <!-- Terms Footer -->
        <p class="text-center text-[10px] mt-3 text-slate-400 leading-relaxed max-w-[280px] mx-auto uppercase tracking-tighter">
            By creating an account, you agree to our 
            <a href="#" class="underline hover:text-slate-600">Terms of Service</a> and 
            <a href="#" class="underline hover:text-slate-600">Privacy Policy</a>.
        </p>
    </div>
    <script>
         //Sysytem Notification
        function handleAction(action) {
            const box = document.getElementById('messageBox');
            const content = document.getElementById('messageContent');
            const title = document.getElementById('messageTitle');
            
            title.innerText = "System Notification";
            content.innerText = `${action}`;
            
            box.classList.remove('hidden');
            box.classList.add('flex');
            box.classList.add('translate-y-2');
            
            setTimeout(() => {
                 box.classList.remove('translate-y-2');
                 hideMessage();
            }, 3000);
        }

        function hideMessage() {
            const box = document.getElementById('messageBox');
            box.classList.add('hidden');
            box.classList.remove('flex');
        }
    </script>
</body>

</html>