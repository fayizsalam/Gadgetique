<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel | Add New Product</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap");
      body {
        font-family: "Inter", sans-serif;
        background-color: #f7f9fb;
      }
      .image-preview-box {
        border: 2px dashed #e5e7eb;
        transition: all 0.3s ease;
      }
      .image-preview-box:hover {
        border-color: #4f46e5;
        background-color: #f5f7ff;
      }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen overflow-hidden">
    <div class="max-w-4xl mx-auto py-4 px-4 sm:px-6 lg:px-8">
      <div
        class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden"
      >
        <!-- Header -->
        <div class="px-6 py-4 bg-indigo-600 text-white grid grid-cols-3 items-center">
          <a href="/admin/dashboard?view=products" class="flex items-center text-indigo-100 hover:text-white transition font-medium">
            <i data-lucide="chevron-left" class="w-5 h-5 mr-1"></i>Back</a>

            <div class="text-center">
                <h1 class="text-2xl font-bold">Add New Product</h1>
                <p class="text-indigo-100 text-sm">
                 Create a new item in your inventory
                </p>
            </div>
        </div>

        

        <!-- Form -->
        <form
          action="/admin/products/addProducts"
          method="post"
          enctype="multipart/form-data"
          class="p-6 space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <!-- Image Upload Column -->
            <div class="md:col-span-1 max-w-[180px]">
              <label class="block text-sm font-semibold text-gray-700 mb-3"
                >Product Image</label
              >
              <div class="flex flex-col items-center">
                <label
                  for="product-image"
                  class="image-preview-box group  w-full aspect-square max-h-[180px] rounded-xl cursor-pointer flex flex-col items-center justify-center relative overflow-hidden bg-gray-50"
                >
                  <!-- Placeholder Icon -->
                  <div
                    id="placeholder-content"
                    class="flex flex-col items-center text-gray-400"
                  >
                    <i data-lucide="image-plus" class="w-12 h-12 mb-2"></i>
                    <span class="text-xs font-medium">Upload Photo</span>
                  </div>

                  <!-- New Image Preview -->
                  <img
                    id="preview-img"
                    src="#"
                    alt="Product Preview"
                    class="hidden absolute inset-0 w-full h-full object-cover"
                  />
                  <!-- Remove button -->
                    <button type="button" id="removeImageBtn" onclick="removeImage()"
                        class="absolute top-2 right-2 z-20 bg-red-600 hover:bg-red-700 text-white text-xs px-2 py-1 rounded-lg shadow opacity-0 group-hover:opacity-100 transition hidden">
                        Remove
                    </button>

                  <!-- Overlay on hover -->
                  <div
                    class="absolute z-10 inset-0 bg-black bg-opacity-0 hover:bg-opacity-40 transition-all flex items-center justify-center group"
                  >
                    <div
                      class="text-white opacity-0 group-hover:opacity-100 flex flex-col items-center transform translate-y-2 group-hover:translate-y-0 transition-all"
                    >
                      <i data-lucide="camera" class="w-8 h-8 mb-1"></i>
                      <span class="text-xs font-bold">Select Image</span>
                    </div>
                  </div>
                </label>
                <input
                  type="file"
                  id="product-image"
                  name="image"
                  class="hidden"
                  accept="image/*"
                  onchange="handleImagePreview(this)"
                  required
                />
                <p class="mt-3 text-xs text-center text-gray-400">
                  PNG, JPG or WEBP (Max 5MB). Required.
                </p>
              </div>
            </div>

            <!-- Details Column -->
            <div class="md:col-span-2 space-y-5">
              <!-- Product Name -->
              <div>
                <label
                  for="name"
                  class="block text-sm font-semibold text-gray-700"
                  >Product Name</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="e.g. Sony WH-1000XM4"
                  class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 p-2.5 bg-gray-50 border transition-all"
                />
              </div>

              <!-- Description -->
              <div>
                <label
                  for="description"
                  class="block text-sm font-semibold text-gray-700"
                  >Description</label
                >
                <textarea
                  id="description"
                  name="description"
                  rows="1"
                  placeholder="Provide a detailed description of the product..."
                  class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                ></textarea>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <!-- Category -->
                <div>
                  <label
                    for="category"
                    class="block text-sm font-semibold text-gray-700"
                    >Category</label
                  >
                  <select
                    id="category"
                    name="category"
                    required
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  >
                    <option value="" disabled selected>Select category</option>
                    <option value="personal">Personal</option>
                    <option value="home">Home</option>
                    <option value="gaming">Gaming</option>
                    <option value="travel">Travel</option>
                    <option value="others">Others</option>
                  </select>
                </div>
                <!-- Brand -->
                <div>
                  <label
                    for="sku"
                    class="block text-sm font-semibold text-gray-700"
                    >Brand</label
                  >
                  <input
                    type="text"
                    id="sku"
                    name="brand"
                    required
                    placeholder=""
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <!-- Price -->
                <div>
                  <label
                    for="price"
                    class="block text-sm font-semibold text-gray-700"
                    >Price (₹)</label
                  >
                  <div class="relative mt-1">
                    <span class="absolute left-3 top-3 text-gray-400">₹</span>
                    <input
                      type="number"
                      id="price"
                      name="price"
                      step="0.01"
                      required
                      placeholder="0.00"
                      class="block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 pl-7 bg-gray-50 border transition-all"
                    />
                  </div>
                </div>

                <!-- Stock -->
                <div>
                  <label
                    for="stock"
                    class="block text-sm font-semibold text-gray-700"
                    >Initial Stock</label
                  >
                  <input
                    type="number"
                    id="stock"
                    name="stock"
                    required
                    placeholder="0"
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  />
                </div>
                <!-- Display Type -->
                <div>
                  <label
                    for="category"
                    class="block text-sm font-semibold text-gray-700"
                    >Display Type</label
                  >
                  <select
                    id=""
                    name="displayType"
                    required
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  >
                    <option value="" disabled selected>Select Type</option>
                    <option value="exclusive">Exclusive</option>
                    <option value="featured">Featured</option>
                    <option value="normal">Normal</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div
            class="pt-4 border-t border-gray-100 flex flex-col sm:flex-row justify-end gap-3"
          >
            <button
              type="button"
              onclick="window.location.href = '/admin/dashboard?view=products'"
              class="px-6 py-3 border border-gray-300 rounded-xl text-gray-700 font-semibold hover:bg-gray-50 transition-all active:scale-95"
            >
              Discard
            </button>
            <button
              type="submit"
              class="px-10 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all active:scale-95 flex items-center justify-center"
            >
              <i data-lucide="plus-circle" class="w-5 h-5 mr-2"></i> Create
              Product
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Toast  -->
    <div id="toast"
  class="fixed top-6 right-6 bg-green-600 text-white px-5 py-3 rounded-xl shadow-lg flex items-center gap-3 opacity-0 translate-y-4 transition-all duration-300 z-50">

  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M5 13l4 4L19 7"/>
  </svg>

  <span id="toastMessage"></span>

  <button onclick="hideToast()" class="ml-2 text-white/80 hover:text-white">
    ✕
  </button>
</div>


    <script>

    function handleImagePreview(input) {
    const preview = document.getElementById('preview-img');
    const placeholder = document.getElementById('placeholder-content');
    const removeBtn = document.getElementById('removeImageBtn');

    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function (e) {
            preview.src = e.target.result;
            preview.classList.remove('hidden');
            placeholder.classList.add('hidden');
            removeBtn.classList.remove('hidden');
        };
        reader.readAsDataURL(input.files[0]);
    }
}

    function removeImage() {
    const input = document.getElementById('product-image');
    const preview = document.getElementById('preview-img');
    const placeholder = document.getElementById('placeholder-content');
    const removeBtn = document.getElementById('removeImageBtn');

    // Clear file input
    input.value = "";

    // Reset UI
    preview.src = "#";
    preview.classList.add('hidden');
    placeholder.classList.remove('hidden');
    removeBtn.classList.add('hidden');
}
      

    // Initialize Lucide Icons
      lucide.createIcons();

   // Toast
function showToast(message, type = "success") {
  const toast = document.getElementById("toast");
  const msg = document.getElementById("toastMessage");

  msg.innerText = message;

  // Reset styles
  toast.classList.remove(
    "opacity-0",
    "translate-y-4",
    "bg-green-600",
    "bg-red-600"
  );

  // Apply type
  if (type === "error") {
    toast.classList.add("bg-red-600");
  } else {
    toast.classList.add("bg-green-600");
  }

  toast.classList.add("opacity-100", "translate-y-0");

  setTimeout(hideToast, 3000);
}

function hideToast() {
  const toast = document.getElementById("toast");
  toast.classList.add("opacity-0", "translate-y-4");
  toast.classList.remove("opacity-100", "translate-y-0");
}

// 🔥 Read messages from URL
const params = new URLSearchParams(window.location.search);
const successMsg = params.get("success");
const errorMsg = params.get("error");

if (successMsg) {
  showToast(successMsg, "success");
}

if (errorMsg) {
  showToast(errorMsg, "error");
}

// 🧹 Clean URL after toast
if (successMsg || errorMsg) {
  window.history.replaceState({}, document.title, window.location.pathname);
}

    </script>
  </body>
</html>
