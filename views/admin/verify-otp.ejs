<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Use Inter font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6; /* Light gray background */
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        /* Custom styling for OTP input area (optional: to make it look like multiple boxes) */
        .otp-input-container {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 0.5rem;
        }
        .otp-input {
            text-align: center;
            font-size: 1.25rem;
            height: 3rem;
        }
    </style>
</head>
<body>

    <!-- OTP Verification Container -->
    <div class="w-full max-w-md p-8 space-y-6 bg-white rounded-xl shadow-2xl border border-gray-100 mx-4 sm:mx-0">
        
        <!-- Header -->
        <div class="text-center">
            <svg class="mx-auto h-10 w-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2v5l-4 4-4-4V9a2 2 0 012-2h4zM16 11H8"></path></svg>
            <h1 class="mt-4 text-2xl font-bold text-gray-900">Verify Code</h1>
            <p class="mt-2 text-sm text-gray-500">
                Please enter the 4-digit verification code sent to your registered email address.
            </p>
        </div>

        <!-- Verification Form -->
        <form class="space-y-6" action="/admin/verify-otp" method="POST">
            
            <input type="hidden" name="email" value="<%= email %>" />

            <!-- Universal Alert System (No Sessions Needed) -->
        <% if (query.error) { %>
        <div class="mb-4 p-2 rounded bg-red-600 text-white text-sm text-center">
          <%= query.error %>
        </div>
        <% } %> <% if (query.success) { %>
        <div
          class="mb-4 p-2 rounded bg-green-600 text-white text-sm text-center"
        >
          <%= query.success %>
        </div>
        <% } %>

            <!-- OTP Field (Single input styled for 4 digits) -->
            <div>
                <label for="otp_code" class="block text-sm font-medium text-gray-700 mb-2">Verification Code</label>
                <input id="otp_code" name="otp" type="text" inputmode="numeric" pattern="[0-9]{4}" required 
                       maxlength="4"
                       placeholder="Enter 4 digits"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 text-2xl tracking-widest text-center focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 transition duration-150">
            </div>

            <!-- Submit Button -->
            <div>
                <button type="submit" 
                        class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-lg text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-200 ease-in-out transform hover:scale-[1.01]">
                    Verify Code
                </button>
            </div>
            
        </form>
        
        <!-- Resend and Back to Login Link -->
        <div class="text-center text-sm pt-4 border-t border-gray-100">
            <p class="text-gray-600 mb-1">Didn't receive the code?</p>
            <a href="/admin/resend-otp?email=<%= email %>" class="font-medium text-indigo-600 hover:text-indigo-500">
                Resend Code
            </a>
            <span class="mx-2 text-gray-400">|</span>
            <a href="/admin/login" class="font-medium text-gray-600 hover:text-indigo-500">
                &larr; Back to login
            </a>
        </div>
    </div>

</body>
</html>