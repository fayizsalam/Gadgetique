<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Load Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      body {
        font-family: "Inter", sans-serif;
        background-color: #f7f9fb;
      }
      .sidebar-link {
        transition: all 0.2s;
      }
      .sidebar-link.active {
        background-color: #4f46e5;
        color: white;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
          0 2px 4px -2px rgba(0, 0, 0, 0.1);
      }
      .sidebar-mobile-overlay {
        transition: opacity 0.3s ease;
      }
      .modal-backdrop {
        background-color: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(2px);
      }
      @keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.animate-slide-in {
  animation: slideIn 0.3s ease-out;
}

    </style>
  </head>
  <body class="min-h-screen flex flex-col lg:flex-row">
    <!-- Mobile Sidebar Toggle -->
    <button
      id="sidebar-toggle"
      class="lg:hidden fixed top-4 left-4 z-40 p-2 bg-indigo-600 text-white rounded-full shadow-lg"
    >
      <i data-lucide="menu"></i>
    </button>

    <!-- Sidebar Overlay -->
    <div
      id="sidebar-overlay"
      class="lg:hidden fixed inset-0 bg-black opacity-0 pointer-events-none z-30 sidebar-mobile-overlay"
    ></div>

    <!-- Sidebar -->
    <nav
      id="sidebar"
      class="fixed inset-y-0 left-0 w-64 bg-gray-800 text-white shadow-xl z-30 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out"
    >
      <div class="p-6">
        <h1 class="text-3xl font-bold text-indigo-400">Admin Panel</h1>
        <p class="text-xs text-gray-400 mt-1">Dashboard Management</p>
      </div>

      <ul class="space-y-2 p-4">
        <li>
          <a
            href="/admin/dashboard"
            data-view="dashboard"
            class="sidebar-link active flex items-center p-3 rounded-xl hover:bg-indigo-700"
          >
            <i data-lucide="layout-dashboard" class="mr-3 w-5 h-5"></i>
            Dashboard
          </a>
        </li>
        <li>
          <a
            href="#"
            data-view="orders"
            class="sidebar-link flex items-center p-3 rounded-xl hover:bg-indigo-700"
          >
            <i data-lucide="truck" class="mr-3 w-5 h-5"></i> Order Management
          </a>
        </li>
        <li>
          <a
            href="#"
            data-view="products"
            class="sidebar-link flex items-center p-3 rounded-xl hover:bg-indigo-700"
          >
            <i data-lucide="package-open" class="mr-3 w-5 h-5"></i> Product
            Management
          </a>
        </li>
        <li>
          <a
            href="#"
            data-view="users"
            class="sidebar-link flex items-center p-3 rounded-xl hover:bg-indigo-700"
          >
            <i data-lucide="users" class="mr-3 w-5 h-5"></i> User Management
          </a>
        </li>
      </ul>

      <div class="absolute bottom-0 w-full p-4 border-t border-gray-700">
        <div class="flex items-center space-x-3">
          <img
            class="w-8 h-8 rounded-full"
            src="https://placehold.co/150x150/4f46e5/ffffff?text=AD"
            alt="Avatar"
          />
          <div>
            <p class="text-sm font-medium text-white">Admin</p>
            <!-- <p class="text-xs text-gray-400">admin@app.com</p> -->
          </div>
        </div>
        <form action="/admin/logout" method="get" class="mt-4">
          <button
            type="submit"
            class="flex items-center p-3 rounded-xl bg-red-600 text-white w-full hover:bg-red-700 transition"
          >
            <i data-lucide="log-out" class="mr-3 w-5 h-5"></i> Logout
          </button>
        </form>
      </div>
    </nav>

    <!-- Main Content Area -->
    <main class="flex-1 p-4 sm:p-8 lg:ml-64 pt-16 lg:pt-8 overflow-y-auto">
      <header class="mb-8">
        <h2 class="text-4xl font-extrabold text-gray-900" id="view-title">
          Dashboard Overview
        </h2>
        <p class="mt-2 text-gray-500" id="view-subtitle">
          Manage your application data efficiently.
        </p>
      </header>

      <div id="content-container">
        <!-- Dashboard View -->
        <section id="dashboard-view" class="view hidden">
          <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8"
          >
            <div
              class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100"
            >
              <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-green-100 rounded-lg text-green-600">
                  <i data-lucide="dollar-sign"></i>
                </div>
              </div>
              <p class="text-sm font-medium text-gray-500">Total Revenue</p>
              <p class="text-3xl font-bold text-gray-900 mt-1">0</p>
            </div>

            <div
              class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100"
            >
              <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-blue-100 rounded-lg text-blue-600">
                  <i data-lucide="shopping-bag"></i>
                </div>
              </div>
              <p class="text-sm font-medium text-gray-500">Total Orders</p>
              <p class="text-3xl font-bold text-gray-900 mt-1">0</p>
            </div>

            <div
              class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100"
            >
              <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-purple-100 rounded-lg text-purple-600">
                  <i data-lucide="box"></i>
                </div>
              </div>
              <p class="text-sm font-medium text-gray-500">Active Products</p>
              <p class="text-3xl font-bold text-gray-900 mt-1"><%= typeof products !== 'undefined' ? products.length : 0 %></p>
            </div>

            <div
              class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100"
            >
              <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-indigo-100 rounded-lg text-indigo-600">
                  <i data-lucide="users"></i>
                </div>
              </div>
              <p class="text-sm font-medium text-gray-500">Total Users</p>
              <p
                class="text-3xl font-bold text-gray-900 mt-1"
                id="total-users-count"
              >
                <%= typeof users !== 'undefined' ? users.length : 0 %>
              </p>
            </div>
          </div>
          <!-- Charts -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Sales Chart -->
            <div class="bg-white p-6 rounded-2xl shadow">
              <h3 class="text-lg font-bold mb-4 text-indigo-900">
                Sales (Monthly)
              </h3>
              <canvas id="salesChart"></canvas>
            </div>

            <!-- Orders Chart -->
            <div class="bg-white p-6 rounded-2xl shadow">
              <h3 class="text-lg font-bold mb-4 text-indigo-900">
                Orders (Weekly)
              </h3>
              <canvas id="ordersChart"></canvas>
            </div>
          </div>

          <!-- Chart.js -->
          <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

          <script>
            // Sales Line Chart
            new Chart(document.getElementById("salesChart"), {
              type: "line",
              data: {
                labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
                datasets: [
                  {
                    label: "Sales",
                    data: [5000, 8000, 6000, 9000, 11000, 15000],
                    borderColor: "#6366F1",
                    backgroundColor: "rgba(99,102,241,0.25)",
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                  },
                ],
              },
              options: {
                responsive: true,
                plugins: { legend: { display: false } },
              },
            });

            // Orders Bar Chart
            new Chart(document.getElementById("ordersChart"), {
              type: "bar",
              data: {
                labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
                datasets: [
                  {
                    label: "Orders",
                    data: [32, 45, 28, 50, 61, 40, 64],
                    backgroundColor: [
                      "#6366F1",
                      "#22C55E",
                      "#F59E0B",
                      "#EF4444",
                      "#3B82F6",
                      "#A855F7",
                      "#14B8A6",
                    ],
                    borderRadius: 8,
                  },
                ],
              },
              options: {
                responsive: true,
                plugins: { legend: { display: false } },
              },
            });
          </script>
        </section>

        <!-- Product Management View -->
        <section id="products-view" class="view hidden">
          <div
            class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100"
          >
            <div
              class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6"
            >
              <div
                class="flex flex-1 w-full max-w-lg items-center bg-gray-100 rounded-xl px-4 py-2"
              >
                <i data-lucide="search" class="w-5 h-5 text-gray-400 mr-2"></i>
                <input
                  type="text"
                  id="product-search-input"
                  placeholder="Search products..."
                  class="bg-transparent border-none focus:ring-0 w-full text-sm"
                />
              </div>
              <div class="flex items-center gap-3 w-full md:w-auto">
                <select
                  id="product-category-filter"
                  class="bg-gray-100 border-none rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-indigo-500"
                >
                  <option value="all">All Categories</option>
                  <option value="personal">Personal</option>
                  <option value="home">Home</option>
                  <option value="gaming">Gaming</option>
                  <option value="travel">Travel</option>
                  <option value="outOfStock">Out of Stock</option>
                  <option value="others">Others</option>
                </select>
                <button
                  onclick="openAddProductModal()"
                  class="px-4 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 flex items-center transition-all shadow-md active:scale-95"
                >
                  <i data-lucide="plus" class="mr-2 w-5 h-5"></i> Add Product
                </button>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Product
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Category
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Brand
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Price
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Stock
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Unit
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Status
                    </th>
                    <th
                      class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody
                  class="bg-white divide-y divide-gray-200"
                  id="product-table-body"
                >
                  <% if (typeof products !== 'undefined' && products.length > 0)
                  { %> <% products.forEach((product, index) => { %>

                  <tr
                    class="product-row"
                    data-category="<%= product.category.toLowerCase() %>"
                    data-stock="<%= product.stock %>"
                  >
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center">
                        <!-- <div
                          class="h-12 w-12 rounded-lg bg-gray-100 flex-shrink-0 flex items-center justify-center overflow-hidden border"
                        > 
                          <img
                            src="public/uploads/products/<%= product.image %>"
                            alt="<%= product.name %>"
                            class="w-full h-full object-cover"
                          />
                        </div> -->
                        <div class="ml-4">
                          <div class="text-sm font-medium text-gray-900">
                            <%= product.name.length > 30 ? product.name.substring(0, 30) + "..." : product.name %>
                          </div>
                          <div class="text-xs text-gray-500">
                            Des: <%= product.description.length > 30 ? product.description.substring(0, 30) + "..." : product.description %>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td
                      class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"
                    >
                      <%= product.category %>
                    </td>
                    <td
                      class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"
                    >
                      <%= product.brand %>
                    </td>
                    <td
                      class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900"
                    >
                      ₹<%= Number(product.price).toLocaleString("en-IN") %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% if (product.stock > 0) { %>
                      <span
                        class="px-2 py-1 rounded-full bg-green-100 text-green-700 text-xs font-bold"
                        >In Stock (<%= product.stock %>)</span
                      >
                      <% } else { %>
                      <span
                        class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-xs font-bold"
                      >
                        Out of Stock(<%= product.stock %>)
                      </span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span
                        class="px-2 py-1 rounded-full text-xs font-bold"
                      >
                        <%= product.unit %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span
                        class="px-2 py-1 rounded-full text-xs font-bold <%= product.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-gray-200 text-gray-600' %>"
                      >
                        <%= product.status %>
                      </span>
                    </td>
                    <td
                      class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium"
                    >
                      <a
                        href="/admin/products/editProducts/<%= product._id %>"
                        class="text-indigo-600 hover:text-indigo-900 mr-3"
                      >
                        Modify
                      </a>
                      <% if (product.status === 'blocked') { %>
                      <button
                        onclick="confirmUnblockProduct('<%= product._id %>')"
                        class="text-green-600 hover:text-green-900"
                      >
                        Unblock
                      </button>
                      <% } else { %>
                      <button
                        onclick="confirmBlockProduct('<%= product._id %>')"
                        class="text-red-600 hover:text-red-900"
                      >
                        Block
                      </button>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %> <% } else { %>

                  <tr>
                    <td colspan="6" class="text-center py-6 text-gray-500">
                      No products found
                    </td>
                  </tr>

                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <!-- User Management View -->
        <section id="users-view" class="view hidden">
          <div
            class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100"
          >
            <div
              class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6"
            >
              <div
                class="flex flex-1 w-full max-w-lg items-center bg-gray-100 rounded-xl px-4 py-2"
              >
                <i data-lucide="search" class="w-5 h-5 text-gray-400 mr-2"></i>
                <input
                  type="text"
                  id="user-search-input"
                  placeholder="Search by name or email..."
                  class="bg-transparent border-none focus:ring-0 w-full text-sm"
                />
              </div>
              <div class="flex items-center gap-3 w-full md:w-auto">
                <select
                  id="user-role-filter"
                  class="bg-gray-100 border-none rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-indigo-500"
                >
                  <option value="all">All Roles</option>
                  <option value="admin">Admin</option>
                  <option value="User">User</option>
                </select>
                <button
                  onclick="openAddUserModal()"
                  class="px-4 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 flex items-center transition-all shadow-md active:scale-95"
                >
                  <i data-lucide="user-plus" class="mr-2 w-5 h-5"></i> New User
                </button>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table
                id="user-table"
                class="min-w-full divide-y divide-gray-200"
              >
                <thead class="bg-gray-50">
                  <tr>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Name
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Email
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Role
                    </th>
                    <th
                      class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Status
                    </th>
                    <th
                      class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"
                    >
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody
                  class="bg-white divide-y divide-gray-200"
                  id="user-table-body"
                >
                  <% if (typeof users !== 'undefined' && users.length > 0) { %>
                  <% users.forEach((user, index) => { %>
                  <tr
                    class="user-row"
                    data-role="<%= (user.role || 'viewer').toLowerCase() %>"
                    data-search="<%= (user.username + ' ' + user.email).toLowerCase() %>"
                  >
                    <td
                      class="px-6 py-4 whitespace-nowrap font-medium text-gray-900"
                    >
                      <%= user.username || 'No Name' %>
                    </td>
                    <td
                      class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"
                    >
                      <%= user.email.replace(/(.{3}).+(@.+)/, '$1****$2') %>
                    </td>
                    <td
                      class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 capitalize"
                    >
                      <%= user.role %>
                    </td>
                    <td class="px-6 py-4">
                      <span
                        class="px-2 py-1 rounded text-xs font-semibold <%= user.status === 'blocked' ? 'bg-red-100 text-red-600': 'bg-green-100 text-green-600' %>"
                      >
                        <%= user.status %>
                      </span>
                    </td>

                    <td
                      class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3"
                    >
                      <button
                        onclick="openEditUserModal('<%= user._id %>', '<%= user.username %>', '<%= user.email %>', '<%= user.role %>')"
                        class="text-indigo-600 hover:text-indigo-900"
                      >
                        Modify
                      </button>
                      <% if (user.status === 'blocked') { %>
                      <button
                        onclick="confirmUnblockUser('<%= user._id %>')"
                        class="text-green-600 hover:text-green-900"
                      >
                        Unblock
                      </button>
                      <% } else { %>
                      <button
                        onclick="confirmBlockUser('<%= user._id %>')"
                        class="text-red-600 hover:text-red-900"
                      >
                        Block
                      </button>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %> <% } else { %>
                  <tr>
                    <td
                      colspan="4"
                      class="px-6 py-10 text-center text-gray-400"
                    >
                      No users found
                    </td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </main>

    <!-- Confirmation Modal -->
    <div
      id="confirm-modal"
      class="fixed inset-0 z-[60] hidden modal-backdrop flex items-center justify-center p-4"
    >
      <div
        class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transform transition-all p-6 text-center"
      >
        <div
          id="confirm-icon-container"
          class="mx-auto flex items-center justify-center h-12 w-12 rounded-full mb-4 bg-red-100 text-red-600"
        >
          <i id="confirm-icon" data-lucide="alert-triangle"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900" id="confirm-title">
          Confirm Action
        </h3>
        <p class="text-sm text-gray-500 mt-2" id="confirm-message">
          Are you sure you want to proceed?
        </p>
        <div class="mt-6 flex gap-3">
          <button
            onclick="closeConfirmModal()"
            class="flex-1 px-4 py-2 border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50 font-medium transition-all"
          >
            Cancel
          </button>
          <button
            id="confirm-action-btn"
            class="flex-1 px-4 py-2 text-white rounded-xl font-medium transition-all shadow-md"
          >
            Confirm
          </button>
        </div>
      </div>
    </div>

    <!-- Edit/Add User Modal -->
    <div
      id="user-modal"
      class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4"
    >
      <div
        class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all"
      >
        <div
          class="p-6 border-b border-gray-100 flex justify-between items-center bg-indigo-50"
        >
          <h3 class="text-xl font-bold text-gray-900" id="modal-title">
            User Details
          </h3>
          <button
            onclick="closeUserModal()"
            class="text-gray-400 hover:text-gray-600 transition-colors"
          >
            <i data-lucide="x"></i>
          </button>
        </div>
        <form
          id="user-form"
          action="/admin/addUser"
          method="POST"
          class="p-6 space-y-4"
        >
          <input type="hidden" id="modal-user-id" name="userId" value="" />
          <div>
            <label class="block text-sm font-medium text-gray-700"
              >Username</label
            >
            <input
              type="text"
              id="modal-username"
              name="username"
              required
              placeholder="Enter full name"
              class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-3 bg-gray-50 border"
            />
          </div>
          <div id="email-field">
            <label class="block text-sm font-medium text-gray-700"
              >Email Address</label
            >
            <input
              type="email"
              id="modal-email"
              name="email"
              required
              placeholder="name@example.com"
              class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-3 bg-gray-50 border"
            />
          </div>
          <div id="password-field">
            <label class="block text-sm font-medium text-gray-700"
              >Password</label
            >
            <input
              type="password"
              id="modal-password"
              name="password"
              required
              placeholder="******"
              class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-3 bg-gray-50 border"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700"
              >User Role</label
            >
            <select
              id="modal-role"
              name="role"
              class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-3 bg-gray-50 border"
            >
              <option value="admin">Admin</option>
              <option value="user">User</option>
            </select>
          </div>
          <div class="pt-4 flex gap-3">
            <button
              type="button"
              onclick="closeUserModal()"
              class="flex-1 px-4 py-2 border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50 transition-all"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="flex-1 px-4 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all shadow-md active:scale-95"
            >
              Save User
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Toast -->
    <div id="toast-container"
     class="fixed top-5 right-5 z-[100] space-y-3">
    </div>

    <script>
      // Global Modal Functions

      function previewProductImage(input) {
        const preview = document.getElementById("image-preview");
        const placeholder = document.getElementById("image-placeholder");

        if (input.files && input.files[0]) {
          const reader = new FileReader();

          reader.onload = function (e) {
            preview.src = e.target.result;
            preview.classList.remove("hidden");
            placeholder.classList.add("hidden");
          };

          reader.readAsDataURL(input.files[0]);
        } else {
          preview.src = "#";
          preview.classList.add("hidden");
          placeholder.classList.remove("hidden");
        }
      }

      function openProductModal() {
        document.getElementById("product-modal").classList.remove("hidden");
      }

      function openAddProductModal() {
        window.location.href = "/admin/products/addProducts";
      }

      function closeProductModal() {
        document.getElementById("product-modal").classList.add("hidden");
        // Reset image preview when closing
        document.getElementById("image-preview").classList.add("hidden");
        document.getElementById("image-placeholder").classList.remove("hidden");
        document.getElementById("product-image-upload").value = "";
      }

      function openAddUserModal() {
        const modal = document.getElementById("user-modal");
        const form = document.getElementById("user-form");
        document.getElementById("modal-title").innerText = "Add New User";
        document.getElementById("modal-user-id").value = "";
        form.action = "/admin/addUser"; // Default create route
        form.reset();
        modal.classList.remove("hidden");
      }

      function openEditUserModal(id, username, email, role) {
        const modal = document.getElementById("user-modal");
        const form = document.getElementById("user-form");
        document.getElementById("modal-title").innerText = "Edit User";
        document.getElementById("modal-user-id").value = id;
        document.getElementById("modal-username").value = username;
        document.getElementById("modal-email").value = email;
        document.getElementById("modal-role").value = role;

        // 🔒 Hide email & password
        document.getElementById("email-field").classList.add("hidden");
        document.getElementById("password-field").classList.add("hidden");

         // ✅ REMOVE required
        document.getElementById("modal-email").removeAttribute("required");
        document.getElementById("modal-password").removeAttribute("required");

        form.action = `/admin/editUser/${id}`; 
        modal.classList.remove("hidden");
      }

      function closeUserModal() {
        document.getElementById("user-modal").classList.add("hidden");
      }

      function closeConfirmModal() {
        document.getElementById("confirm-modal").classList.add("hidden");
      }

      function confirmBlockUser(userId) {
        const modal = document.getElementById("confirm-modal");
        const actionBtn = document.getElementById("confirm-action-btn");
        document.getElementById("confirm-title").innerText = "Block User";
        document.getElementById("confirm-message").innerText =
          "Are you sure you want to block this user? They will lose access immediately.";

        actionBtn.className =
          "flex-1 px-4 py-2 bg-red-600 text-white rounded-xl font-medium transition-all shadow-md hover:bg-red-700";
        actionBtn.onclick = () => {
          const form = document.createElement("form");
          form.method = "POST";
          form.action = `/admin/blockUser/${userId}/block`;
          document.body.appendChild(form);
          form.submit();
        };
        modal.classList.remove("hidden");
      }

      function confirmUnblockUser(userId) {
        const modal = document.getElementById("confirm-modal");
        const actionBtn = document.getElementById("confirm-action-btn");

        document.getElementById("confirm-title").innerText = "Unblock User";
        document.getElementById("confirm-message").innerText =
          "Are you sure you want to unblock this user? They will regain access.";

        actionBtn.className =
          "flex-1 px-4 py-2 bg-green-600 text-white rounded-xl font-medium transition-all shadow-md hover:bg-green-700";

        actionBtn.onclick = () => {
          const form = document.createElement("form");
          form.method = "POST";
          form.action = `/admin/unblockUser/${userId}/unblock`;
          document.body.appendChild(form);
          form.submit();
        };

        modal.classList.remove("hidden");
      }

      function confirmBlockProduct(productId) {
        const modal = document.getElementById("confirm-modal");
        const actionBtn = document.getElementById("confirm-action-btn");
        document.getElementById("confirm-title").innerText = "Block Product";
        document.getElementById("confirm-message").innerText =
          "Are you sure you want to block this product?";

        actionBtn.className =
          "flex-1 px-4 py-2 bg-red-600 text-white rounded-xl font-medium transition-all shadow-md hover:bg-red-700";
        actionBtn.onclick = () => {
          const form = document.createElement("form");
          form.method = "POST";
          form.action = `/admin/products/status/${productId}`;
          document.body.appendChild(form);
          form.submit();
        };
        modal.classList.remove("hidden");
      }

      function confirmUnblockProduct(productId) {
  const modal = document.getElementById("confirm-modal");
  const actionBtn = document.getElementById("confirm-action-btn");

  document.getElementById("confirm-title").innerText = "Unblock Product";
  document.getElementById("confirm-message").innerText =
    "Are you sure you want to unblock this product? It will be visible to users.";

  actionBtn.className =
    "flex-1 px-4 py-2 bg-green-600 text-white rounded-xl font-medium transition-all shadow-md hover:bg-green-700";

  actionBtn.onclick = () => {
    const form = document.createElement("form");
    form.method = "POST";
    form.action = `/admin/products/status/${productId}`;
    document.body.appendChild(form);
    form.submit();
  };

  modal.classList.remove("hidden");
}

      document.addEventListener("DOMContentLoaded", () => {
        lucide.createIcons();

        const sidebar = document.getElementById("sidebar");
        const toggleButton = document.getElementById("sidebar-toggle");
        const overlay = document.getElementById("sidebar-overlay");
        const viewLinks = document.querySelectorAll(".sidebar-link");
        const searchInput = document.getElementById("user-search-input");
        const roleFilter = document.getElementById("user-role-filter");

        if (toggleButton)
          toggleButton.onclick = () =>
            sidebar.classList.remove("-translate-x-full");
        if (overlay)
          overlay.onclick = () => sidebar.classList.add("-translate-x-full");

        function showView(viewId) {
          document
            .querySelectorAll(".view")
            .forEach((v) => v.classList.add("hidden"));
          const target = document.getElementById(`${viewId}-view`);
          if (target) target.classList.remove("hidden");

          viewLinks.forEach((l) =>
            l.classList.toggle("active", l.dataset.view === viewId)
          );

          document.getElementById("view-title").innerText =
            viewId.charAt(0).toUpperCase() + viewId.slice(1) + " Overview";

          if (window.innerWidth < 1024) {
            sidebar.classList.add("-translate-x-full");
          }
        }

        viewLinks.forEach((link) =>
          link.addEventListener("click", (e) => {
            e.preventDefault();
            showView(link.dataset.view);
          })
        );

        function filterUsers() {
          if (!searchInput) return;
          const q = searchInput.value.toLowerCase();
          const role = roleFilter ? roleFilter.value.toLowerCase() : "all";

          document.querySelectorAll(".user-row").forEach((row) => {
            const matchesSearch = row.dataset.search.includes(q);
            const matchesRole = role === "all" || row.dataset.role === role;
            row.classList.toggle("hidden", !(matchesSearch && matchesRole));
          });
        }

        if (searchInput) searchInput.addEventListener("input", filterUsers);
        if (roleFilter) roleFilter.addEventListener("change", filterUsers);

        // ---------------- PRODUCT FILTER (Search + Category) ----------------
      const productSearchInput = document.getElementById("product-search-input");
      const productCategoryFilter = document.getElementById("product-category-filter");

      function filterProducts() {
  const searchText = productSearchInput.value.toLowerCase();
  const selectedCategory = productCategoryFilter.value.toLowerCase();

  document.querySelectorAll(".product-row").forEach((row) => {
    const productName = row.querySelector(".text-gray-900").innerText.toLowerCase();
    const productCategory = row.dataset.category;
    const productStock = Number(row.dataset.stock);

    const matchesSearch = productName.includes(searchText);

    let matchesCategory = false;

    if (selectedCategory === "all") {
      matchesCategory = true;
    } 
    else if (selectedCategory === "outofstock") {
      matchesCategory = productStock <= 0;
    } 
    else {
      matchesCategory = productCategory === selectedCategory;
    }

    row.classList.toggle("hidden", !(matchesSearch && matchesCategory));
  });
}

      // Live search
if (productSearchInput) {
  productSearchInput.addEventListener("input", filterProducts);
}

// Category filter
if (productCategoryFilter) {
  productCategoryFilter.addEventListener("change", filterProducts);
}


        const params = new URLSearchParams(window.location.search);
        const initialView = params.get("view") || "dashboard";
        showView(initialView);
      });

      //Toast
  function showToast(message, type = "success", duration = 4000) {
    const toast = document.createElement("div");

    const colors = {
      success: "bg-green-600",
      error: "bg-red-600",
      warning: "bg-yellow-500",
      info: "bg-blue-600"
    };

    toast.className = `
      flex items-start gap-3 px-4 py-3 rounded-xl shadow-lg text-white
      ${colors[type]}
      animate-slide-in
    `;

    toast.innerHTML = `
      <div class="flex-1 text-sm font-medium">${message}</div>
      <button class="text-white/80 hover:text-white text-lg leading-none">&times;</button>
    `;

    // Close button
    toast.querySelector("button").onclick = () => {
      toast.remove();
    };

    document.getElementById("toast-container").appendChild(toast);

    // Auto remove
    setTimeout(() => {
      toast.classList.add("opacity-0");
      setTimeout(() => toast.remove(), 300);
    }, duration);
  }

  const params = new URLSearchParams(window.location.search);

  if (params.get("success")) {
    showToast(params.get("success"), "success");
  }

  if (params.get("error")) {
    showToast(params.get("error"), "error");
  }
    </script>

  </body>
</html>
