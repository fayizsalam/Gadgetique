<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel Signup</title>
    <!-- Load Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Configure Tailwind for custom colors and use Inter font -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-blue': '#1D4ED8',
                        'secondary-gray': '#F3F4F6',
                    },
                },
                fontFamily: {
                    sans: ['Inter', 'sans-serif'],
                },
            },
        }
    </script>
    <style>
        /* Ensuring full viewport height and centering content */
        .login-bg {
            background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
        }
        /* Custom message box styling (in case of an error/alert) */
        .message-box {
            display: none;
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 50;
        }
    </style>
</head>
<body class="font-sans min-h-screen login-bg flex items-center justify-center p-4">

    <!-- Signup Container Card -->
    <div class="w-full max-w-md bg-white rounded-xl shadow-2xl p-8 space-y-6 transform hover:scale-[1.01] transition-transform duration-300">
        
        <!-- Signup Content -->
        <div>
            <div class="text-center">
                <svg class="w-12 h-12 mx-auto text-primary-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0z"></path>
                </svg>
                <h1 class="text-3xl font-extrabold text-gray-900 mt-4">
                    Create Admin Account
                </h1>
                <p class="text-sm text-gray-500 mt-2">
                    Register for access to the system panel.
                </p>
            </div>
 
            <form id="signupForm" class="space-y-5 mt-6" action="/admin/signup"  method="post">

                 <!-- Universal Alert System (No Sessions Needed) -->
        <% if (query.error) { %>
        <div class="mb-4 p-2 rounded bg-red-600 text-white text-sm text-center">
          <%= query.error %>
        </div>
        <% } %> <% if (query.success) { %>
        <div
          class="mb-4 p-2 rounded bg-green-600 text-white text-sm text-center"
        >
          <%= query.success %>
        </div>
        <% } %>
                
                <!-- Full Name Input -->
                <div>
                    <label for="signup-name" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                    <input type="text" id="signup-name" name="username" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-blue focus:border-primary-blue transition duration-150 shadow-sm">
                </div>

                <!-- Email Input -->
                <div>
                    <label for="signup-email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                    <input type="email" id="signup-email" name="email" required autocomplete="email"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-blue focus:border-primary-blue transition duration-150 shadow-sm">
                </div>

                <!-- Password Input -->
                <div>
                    <label for="signup-password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" id="signup-password" name="password" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-blue focus:border-primary-blue transition duration-150 shadow-sm">
                </div>

                <!-- Confirm Password Input -->
                <div>
                    <label for="signup-confirm-password" class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                    <input type="password" id="signup-confirm-password" name="confirmPassword" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-blue focus:border-primary-blue transition duration-150 shadow-sm">
                </div>
                
                <!-- Submit Button -->
                <div>
                    <button type="submit"
                            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-md text-lg font-bold text-white bg-primary-blue hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-500 focus:ring-opacity-50 transition duration-200 ease-in-out transform active:scale-95">
                        Sign Up
                    </button>
                </div>
            </form>

            <p class="mt-6 text-center text-sm text-gray-600">
                Already have an account? 
                <!-- Link to the separate login page -->
                <a href="/admin/login" class="font-medium text-primary-blue hover:text-blue-700 transition duration-150">
                    Sign In
                </a>
            </p>
        </div>
    </div>
</body>
</html>