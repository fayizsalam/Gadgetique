<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product | Admin Panel</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f7f9fb; }
        .image-preview-box {
            border: 2px dashed #e5e7eb;
            transition: all 0.3s ease;
        }
        .image-preview-box:hover {
            border-color: #4f46e5;
            background-color: #f5f7ff;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">

    <div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumbs / Back Link -->
        <nav class="mb-8 flex items-center text-sm font-medium text-gray-500">
            <a href="/admin/dashboard?view=products" class="flex items-center hover:text-indigo-600 transition-colors">
                <i data-lucide="chevron-left" class="w-4 h-4 mr-1"></i>
                Back to Products
            </a>
        </nav>

        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
            <!-- Header -->
            <div class="px-8 py-6 bg-indigo-600 text-white">
                <h1 class="text-2xl font-bold">Edit Product</h1>
                <p class="text-indigo-100 text-sm mt-1">Update details for "<%= product.name %>"</p>
            </div>

            <!-- Form -->
        <form
          action="/admin/products/editproducts/<%= product._id %>"
          method="post"
          enctype="multipart/form-data"
          class="p-8 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Image Upload Column -->
            <div class="md:col-span-1 max-w-[180px]">
              <label class="block text-sm font-semibold text-gray-700 mb-3"
                >Product Image</label
              >
              <div class="flex flex-col items-center">
                <label
                  for="product-image"
                  class="image-preview-box group  w-full aspect-square max-h-[180px] rounded-xl cursor-pointer flex flex-col items-center justify-center relative overflow-hidden bg-gray-50"
                >
                  <!-- Placeholder Icon -->
                  <div
                    id="placeholder-content"
                    class="flex flex-col items-center text-gray-400"
                  >
                    <i data-lucide="image-plus" class="w-12 h-12 mb-2"></i>
                    <span class="text-xs font-medium">Upload Photo</span>
                  </div>

                  <!-- Image Preview -->
                  <img
                    id="preview-img"
                    src="/uploads/products/<%= product.image %>"
                    alt="Product Preview"
                    class=" absolute inset-0 w-full h-full object-cover"
                  />
                  <!-- Remove button -->
                    <button type="button" id="removeImageBtn" onclick="removeImage()"
                        class="absolute top-2 right-2 z-20 bg-red-600 hover:bg-red-700 text-white text-xs px-2 py-1 rounded-lg shadow opacity-0 group-hover:opacity-100 transition hidden">
                        Remove
                    </button>

                  <!-- Overlay on hover -->
                  <div
                    class="absolute z-10 inset-0 bg-black bg-opacity-0 hover:bg-opacity-40 transition-all flex items-center justify-center group"
                  >
                    <div
                      class="text-white opacity-0 group-hover:opacity-100 flex flex-col items-center transform translate-y-2 group-hover:translate-y-0 transition-all"
                    >
                      <i data-lucide="camera" class="w-8 h-8 mb-1"></i>
                      <span class="text-xs font-bold">Select Image</span>
                    </div>
                  </div>
                </label>
                <input
                  type="file"
                  id="product-image"
                  name="image"
                  class="hidden"
                  accept="image/*"
                  onchange="handleImagePreview(this)"
                />
                <p class="mt-3 text-xs text-center text-gray-400">
                  PNG, JPG or WEBP (Max 5MB). Required.
                </p>
              </div>
            </div>

            <!-- Details Column -->
            <div class="md:col-span-2 space-y-5">
              <!-- Product Name -->
              <div>
                <label
                  for="name"
                  class="block text-sm font-semibold text-gray-700"
                  >Product Name</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  value="<%= product.name %>"
                  required
                  class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 p-2.5 bg-gray-50 border transition-all"
                />
              </div>

              <!-- Description -->
              <div>
                <label
                  for="description"
                  class="block text-sm font-semibold text-gray-700"
                  >Description</label
                >
                <textarea
                  id="description"
                  name="description"
                  rows="1"
                  class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                ><%= product.description %></textarea>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <!-- Category -->
                <div>
                  <label
                    for="category"
                    class="block text-sm font-semibold text-gray-700"
                    >Category</label
                  >
                  <select
                    id="category"
                    name="category"
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  >
                    <option value="personal" <%= product.category === "personal" ? "selected" : "" %>>Personal</option>
                                    <option value="home" <%= product.category === "home" ? "selected" : "" %>>Home</option>
                                    <option value="gaming" <%= product.category === "gaming" ? "selected" : "" %>>Gaming</option>
                                    <option value="travel" <%= product.category === "travel" ? "selected" : "" %>>Travel</option>
                                    <option value="others" <%= product.category === "others" ? "selected" : "" %>>Others</option>
                                </select>
                </div>
                <!-- Brand -->
                <div>
                  <label
                    for="sku"
                    class="block text-sm font-semibold text-gray-700"
                    >Brand</label
                  >
                  <input
                    type="text"
                    id="sku"
                    name="brand"
                    value="<%= product.brand %>"
                    required
                    placeholder=""
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <!-- Price -->
                <div>
                  <label
                    for="price"
                    class="block text-sm font-semibold text-gray-700"
                    >Price (₹)</label
                  >
                  <div class="relative mt-1">
                    <span class="absolute left-3 top-3 text-gray-400">₹</span>
                    <input
                      type="number"
                      id="price"
                      name="price"
                      step="0.01"
                      value="<%= product.price %>"
                      required
                      class="block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 pl-7 bg-gray-50 border transition-all"
                    />
                  </div>
                </div>

                <!-- Stock -->
                <div>
                  <label
                    for="stock"
                    class="block text-sm font-semibold text-gray-700"
                    >Current Stock</label
                  >
                  <input
                    type="number"
                    id="stock"
                    name="stock"
                    required
                    value="<%= product.stock %>"
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  />
                </div>
                <!-- Display Type -->
                <div>
                  <label
                    for="displayType"
                    class="block text-sm font-semibold text-gray-700"
                    >Display Type</label>
                  <select
                    id="displayType"
                    name="displayType"
                    class="mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 p-2.5 bg-gray-50 border transition-all"
                  >
                  <option value="normal" <%= product.displayType === "normal" ? "selected" : "" %>>Normal</option>
                    <option value="exclusive" <%= product.displayType === "exclusive" ? "selected" : "" %>>Exclusive</option>
                    <option value="featured" <%= product.displayType === "featured" ? "selected" : "" %>>Featured</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div
            class="pt-4 border-t border-gray-100 flex flex-col sm:flex-row justify-end gap-3"
          >
            <button
              type="button"
              onclick="window.location.href='/admin/dashboard?view=products'"
              class="px-6 py-3 border border-gray-300 rounded-xl text-gray-700 font-semibold hover:bg-gray-50 transition-all active:scale-95"
            >
              Discard
            </button>
            <button
              type="submit"
              class="px-10 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all active:scale-95 flex items-center justify-center"
            >
              <i data-lucide="plus-circle" class="w-5 h-5 mr-2"></i> Update
              Product
            </button>
          </div>
        </form>
        </div>
    </div>

    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Handle Real-time Image Preview
  function handleImagePreview(input) {
    const preview = document.getElementById('preview-img');
    const placeholder = document.getElementById('placeholder-content');
    const removeBtn = document.getElementById('removeImageBtn');

    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function (e) {
            preview.src = e.target.result;
            preview.classList.remove('hidden');
            placeholder.classList.add('hidden');
            removeBtn.classList.remove('hidden');
        };
        reader.readAsDataURL(input.files[0]);
    }
}

    function removeImage() {
    const input = document.getElementById('product-image');
    const preview = document.getElementById('preview-img');
    const placeholder = document.getElementById('placeholder-content');
    const removeBtn = document.getElementById('removeImageBtn');

    // Clear file input
    input.value = "";

    // Reset UI
    preview.src = "#";
    preview.classList.add('hidden');
    placeholder.classList.remove('hidden');
    removeBtn.classList.add('hidden');
}
    </script>
</body>
</html>